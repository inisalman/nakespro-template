---
// components/Hero.astro — section 1, selalu render (R5.5), tidak Auto-Hide.
//
// Menampilkan (R3.3, R11.2, R11.4):
//   - Tepat satu <h1> halaman (websiteName) → struktur heading (Property 13).
//   - Tagline opsional sebagai sub-judul.
//   - Foto utama dari content.heroPhoto dengan width/height eksplisit +
//     fetchpriority high (above-the-fold, tidak lazy) (R3.3, R10.8, Property 14).
//   - WhatsApp_CTA above-the-fold dengan accessible name tidak kosong (R3.3,
//     R3.4, R11.4). CTA selalu tampil di Hero (berbeda dari floating yang
//     hilang bila invalid); href tetap dibangun dari nomor.
// Warna hanya via CSS var (R6.4).
import type { SiteContent } from '../types.ts';
import { buildWaUrl, isValidWaNumber } from '../lib/whatsapp.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const heroPhoto = content.heroPhoto;
const heroAlt = heroPhoto
  ? resolveAltText(heroPhoto)
  : `Foto ${content.websiteName}`;
const heroSrc = heroPhoto ? `/images/${heroPhoto.url}` : undefined;
const waValid = isValidWaNumber(content.waNumber);
const waHref = buildWaUrl(content.waNumber, content.waMessage);
---

<section class="hero" aria-labelledby="hero-h">
  <div class="container hero-grid">
    <div class="hero-copy">
      <h1 id="hero-h">{content.websiteName}</h1>
      {content.tagline && <p class="hero-tagline">{content.tagline}</p>}
      <p class="hero-desc">{content.description}</p>
      {
        waValid && (
          <a
            class="hero-cta"
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Hubungi kami via WhatsApp"
          >
            Hubungi via WhatsApp
          </a>
        )
      }
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-num" data-target="1000">0+</span>
          <span class="hero-stat-label">Pasien Dilayani</span>
        </div>
        <div class="hero-stat-divider" aria-hidden="true" />
        <div class="hero-stat">
          <span class="hero-stat-num">5 Tahun</span>
          <span class="hero-stat-label">Pengalaman</span>
        </div>
        <div class="hero-stat-divider" aria-hidden="true" />
        <div class="hero-stat">
          <span class="hero-stat-num">
            <span class="hero-stat-stars" aria-hidden="true">★★★★★</span>
            4.9<span class="hero-stat-of">/5</span>
          </span>
          <span class="hero-stat-label">Rating Pasien</span>
        </div>
      </div>
    </div>
    {
      heroSrc && (
        <div class="hero-media">
          <img
            src={heroSrc}
            alt={heroAlt}
            width="640"
            height="640"
            decoding="async"
            fetchpriority="high"
          />
          <ul class="hero-badges" aria-label="Kredensial perawat">
            <li class="hero-badge hero-badge--1">
              <span class="hero-badge-ico" aria-hidden="true">
                🩺
              </span>
              <span class="hero-badge-txt">Perawat ber-STR aktif</span>
            </li>
            <li class="hero-badge hero-badge--2">
              <span class="hero-badge-ico" aria-hidden="true">
                🏅
              </span>
              <span class="hero-badge-txt">Sertifikat perawatan luka</span>
            </li>
            <li class="hero-badge hero-badge--3">
              <span class="hero-badge-ico" aria-hidden="true">
                📋
              </span>
              <span class="hero-badge-txt">Pelatihan BTCLS</span>
            </li>
          </ul>
        </div>
      )
    }
  </div>
</section>

<style>
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .hero {
    background: var(--surface);
  }
  .hero-grid {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  /* Animasi per elemen dengan delay bertahap */
  .hero-copy h1 {
    font-size: clamp(1.9rem, 5vw, 3rem);
    margin: 0 0 0.5rem;
    animation: fadeSlideUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.05s;
  }
  .hero-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 0.75rem;
    animation: fadeSlideUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.2s;
  }
  .hero-desc {
    color: var(--muted);
    margin: 0 0 1.5rem;
    max-width: 60ch;
    animation: fadeSlideUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.35s;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    background: var(--accent);
    color: var(--background);
    font-weight: 600;
    text-decoration: none;
    animation: fadeSlideUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.5s;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    animation: fadeSlideUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.65s;
  }
  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .hero-stat-num {
    font-size: clamp(1.4rem, 3vw, 1.75rem);
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .hero-stat-of {
    font-size: 0.9rem;
    font-weight: 600;
    opacity: 0.7;
  }
  .hero-stat-stars {
    font-size: 0.75rem;
    color: var(--star);
    letter-spacing: -0.05em;
  }
  .hero-stat-label {
    font-size: 0.8rem;
    color: var(--muted);
    font-weight: 500;
  }
  .hero-stat-divider {
    width: 1px;
    height: 2.5rem;
    background: color-mix(in srgb, var(--muted) 30%, transparent);
    flex-shrink: 0;
  }
  .hero-media {
    animation: fadeIn 0.8s ease both;
    animation-delay: 0.2s;
    position: relative;
  }
  .hero-media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    object-fit: cover;
  }

  /* Badge kredensial melayang di pinggir foto */
  @keyframes badgeFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  @keyframes badgePop {
    from {
      opacity: 0;
      transform: scale(0.8) translateY(8px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
  .hero-badges {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-badge {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.9rem;
    background: var(--background);
    border-radius: 999px;
    box-shadow: var(--shadow-card-hover);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    pointer-events: auto;
    /* pop masuk dulu, lalu melayang berulang */
    animation:
      badgePop 0.5s cubic-bezier(0.22, 1, 0.36, 1) both,
      badgeFloat 4s ease-in-out infinite;
  }
  .hero-badge-ico {
    font-size: 1.05rem;
    line-height: 1;
  }
  .hero-badge--1 {
    top: 8%;
    left: -4%;
    animation-delay: 0.7s, 0.7s;
  }
  .hero-badge--2 {
    top: 44%;
    right: -5%;
    animation-delay: 0.95s, 1.4s;
  }
  .hero-badge--3 {
    bottom: 9%;
    left: 2%;
    animation-delay: 1.2s, 2.1s;
  }
  @media (max-width: 640px) {
    .hero-badge {
      font-size: 0.75rem;
      padding: 0.45rem 0.7rem;
    }
    .hero-badge--1 {
      left: 0;
    }
    .hero-badge--2 {
      right: 0;
    }
  }

  /* Hormati preferensi reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-copy h1,
    .hero-tagline,
    .hero-desc,
    .hero-cta,
    .hero-stats,
    .hero-media,
    .hero-badge {
      animation: none;
    }
  }
</style>

<script>
  // Count-up animasi untuk stat "1000+"
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    const el = document.querySelector('[data-target="1000"]') as HTMLElement | null;
    if (el) {
      const duration = 1800;
      const target = 1000;
      const start = performance.now();
      const tick = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        // ease-out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(eased * target);
        el.textContent = current >= target ? '1000+' : `${current}+`;
        if (progress < 1) requestAnimationFrame(tick);
      };
      // Mulai saat elemen masuk viewport
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            requestAnimationFrame(tick);
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.5 });
      io.observe(el);
    }
  }
</script>
