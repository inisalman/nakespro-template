---
// components/PhotoGallery.astro — section 5, Auto-Hide galeri (R3.8,
// R3.13, R5.3, Property 5/8).
//
// Aturan render:
//   - Section dirender bila ada ≥1 foto; bila galeri kosong → return null
//     (R5.3).
//   - Seluruh foto digabung ke SATU grid tunggal (tanpa sub-heading kategori),
//     urutan sesuai daftar (R3.13).
//   - Tiap gambar: width/height eksplisit, loading="lazy" (below-the-fold,
//     R10.8 Property 14), format modern (.webp di public/images), alt via
//     resolveAltText (R11.1).
// Gaya Bloom & Bone: bingkai foto krem, caption muncul halus saat hover/fokus.
// Warna via CSS var saja (R6.4).
import type { Photo } from '../types.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  photos?: Photo[];
}

const { photos } = Astro.props;

const items = photos ?? [];

if (items.length === 0) return null;
---

<section class="gallery" aria-labelledby="gallery-h">
  <div class="container">
    <div class="gallery-head">
      <span class="kicker">Dokumentasi</span>
      <h2 id="gallery-h" data-reveal style="animation-delay:.1s" class="section-title">Galeri</h2>
    </div>
    <ul class="gallery-grid" role="list">
      {
        items.map((photo) => (
          <li class="gallery-item">
            <figure class="gallery-fig">
              <img
                src={`/images/${photo.url}`}
                alt={resolveAltText(photo)}
                width="400"
                height="300"
                loading="lazy"
                decoding="async"
              />
              {photo.caption && (
                <figcaption class="gallery-cap">{photo.caption}</figcaption>
              )}
            </figure>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .gallery-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }
  .gallery-item {
    margin: 0;
  }
  .gallery-fig {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow);
    aspect-ratio: 4 / 3;
    background: var(--card);
    transition: box-shadow 0.4s ease, border-color 0.4s ease;
  }
  .gallery-fig:hover {
    box-shadow: var(--shadow-lg);
    border-color: var(--hairline-strong);
  }
  .gallery-fig img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-fig:hover img {
    transform: scale(1.06);
  }
  .gallery-cap {
    position: absolute;
    inset: auto 0.75rem 0.75rem 0.75rem;
    padding: 0.85rem 1.1rem;
    font-size: 0.84rem;
    font-weight: 700;
    color: var(--ink);
    background: color-mix(in srgb, var(--card) 88%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-fig:hover .gallery-cap,
  .gallery-fig:focus-within .gallery-cap {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery-fig img {
      transition: none;
    }
  }
</style>
