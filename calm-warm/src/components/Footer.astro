---
// components/Footer.astro — selalu render, dikecualikan dari Auto-Hide (R5.5).
//
// Menampilkan teks kecil "Powered by NakesPro" (R3.15). Gaya Bloom & Bone:
// baris meta minimal di atas garis tipis krem dengan dot brand. Warna hanya via
// CSS custom properties hasil palette/token (R6.4) — tanpa nilai warna literal.
---

<footer class="site-footer">
  <div class="container footer-inner">
    <span class="footer-brand">
      <span class="footer-dot" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20c0-4.5.7-7.6 2.9-9.8C16.9 8.2 19 7.6 19 7.6s.2 2.7-1.4 5C15.8 14.8 13.4 15.3 12 15.3Z" />
          <path d="M12 20c0-3.8-.6-6.3-2.4-8.3C7.7 9.9 5.6 9.3 5.6 9.3s-.2 2.4 1.2 4.5C8.4 15.6 10.6 16 12 16Z" />
          <path d="M12 20v-4.5" />
        </svg>
      </span>
      Dengan perawatan & ketenangan
    </span>
    <p class="powered">Powered by NakesPro</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--hairline);
    background: var(--paper-2);
    padding-block: 2rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
  }
  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink);
  }
  .footer-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--on-ink);
  }
  .powered {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }
</style>
