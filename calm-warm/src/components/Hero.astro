---
// components/Hero.astro — section 1, selalu render (R5.5), tidak Auto-Hide.
//
// Menampilkan (R3.3, R11.2, R11.4):
//   - Tepat satu <h1> halaman (websiteName) → struktur heading (Property 13).
//   - Tagline opsional sebagai kicker pill di atas judul.
//   - Foto utama dari content.heroPhoto dengan width/height eksplisit +
//     fetchpriority high (above-the-fold, tidak lazy) (R3.3, R10.8, Property 14).
//   - WhatsApp_CTA above-the-fold dengan accessible name tidak kosong (R3.3,
//     R3.4, R11.4). CTA selalu tampil di Hero (berbeda dari floating yang
//     hilang bila invalid); href tetap dibangun dari nomor.
//   - Badge kredensial mengambang + dua chip info gelap (jam & lokasi) bila ada.
// Gaya Bloom & Bone: kartu krem + foto berbingkai bertumpuk. Warna hanya via
// var(--token)/color-mix (R6.4).
import type { SiteContent } from '../types.ts';
import { buildWaUrl, isValidWaNumber } from '../lib/whatsapp.ts';
import { resolveAltText } from '../lib/images.ts';
import { isEmptyText } from '../lib/empty.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const heroPhoto = content.heroPhoto;
const heroAlt = heroPhoto
  ? resolveAltText(heroPhoto)
  : `Foto ${content.websiteName}`;
const heroSrc = heroPhoto ? `/images/${heroPhoto.url}` : undefined;
const waValid = isValidWaNumber(content.waNumber);
const waHref = buildWaUrl(content.waNumber, content.waMessage);
const badge = content.credentials?.[0];
const hasHours = !isEmptyText(content.practiceHours);
const hasLocation = !isEmptyText(content.location);
---

<section class="hero" aria-labelledby="hero-h">
  <div class="container hero-grid">
    <div class="hero-card">
      {
        content.tagline && (
          <span class="kicker">{content.tagline}</span>
        )
      }
      <h1 id="hero-h" class="hero-title">{content.websiteName}</h1>
      <p class="hero-desc">{content.description}</p>
      <div class="hero-actions">
        {
          waValid && (
            <a
              class="btn btn-primary"
              href={waHref}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Hubungi kami via WhatsApp"
            >
              Hubungi via WhatsApp
            </a>
          )
        }
        <a class="btn btn-ghost" href="#services-h">
          Lihat Layanan
          <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
    </div>

    {
      heroSrc && (
        <div class="hero-media">
          <div class="hero-frame">
            <img
              src={heroSrc}
              alt={heroAlt}
              width="640"
              height="560"
              decoding="async"
              fetchpriority="high"
            />
            {badge && (
              <div class="hero-badge">
                <span class="hero-badge-icon" aria-hidden="true">
                  {badge.icon}
                </span>
                <span class="hero-badge-text">{badge.label}</span>
              </div>
            )}
          </div>
          {(hasHours || hasLocation) && (
            <div class="hero-chips">
              {hasHours && (
                <div class="hero-chip">
                  <span class="hero-chip-k">Jam</span>
                  <span class="hero-chip-v">{content.practiceHours}</span>
                </div>
              )}
              {hasLocation && (
                <div class="hero-chip">
                  <span class="hero-chip-k">Lokasi</span>
                  <span class="hero-chip-v">{content.location}</span>
                </div>
              )}
            </div>
          )}
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(1.75rem, 4vw, 3rem);
  }
  .hero-grid {
    display: grid;
    gap: clamp(1.25rem, 3vw, 1.75rem);
    align-items: stretch;
  }
  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: 1.02fr 0.98fr;
    }
  }
  .hero-card {
    background: var(--card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: clamp(1.75rem, 4vw, 3.25rem);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-title {
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.025em;
    margin: 0 0 1.35rem;
  }
  .hero-desc {
    color: var(--ink-soft);
    font-size: clamp(1rem, 1.8vw, 1.12rem);
    margin: 0 0 2rem;
    max-width: 42ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 50px;
    padding: 0.85rem 1.6rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--on-accent);
    box-shadow: var(--shadow-sm);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .btn-ghost {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--hairline-strong);
  }
  .btn-ghost:hover {
    background: var(--paper-2);
    border-color: var(--ink);
  }

  .hero-media {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .hero-frame {
    position: relative;
    flex: 1;
    min-height: 280px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-sm);
  }
  .hero-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--card) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-sm);
    max-width: 13rem;
  }
  .hero-badge-icon {
    flex: none;
    font-size: 1rem;
    line-height: 1;
    color: var(--accent);
  }
  .hero-badge-text {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--ink);
    line-height: 1.2;
  }
  .hero-chips {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .hero-chip {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.85rem 1.1rem;
    border-radius: var(--radius);
    background: var(--ink);
    color: var(--on-ink);
    min-width: 0;
  }
  .hero-chip-k {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--on-ink) 60%, transparent);
  }
  .hero-chip-v {
    font-size: 0.86rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  @media (max-width: 420px) {
    .hero-chips {
      grid-template-columns: 1fr;
    }
  }
</style>
