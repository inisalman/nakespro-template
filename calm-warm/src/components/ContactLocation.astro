---
// components/ContactLocation.astro — section 8, Auto-Hide penuh + partial
// (R3.11, R3.14, R5.3, R5.6, Property 5).
//
// Aturan render:
//   - Section dirender bila ≥1 sub-field (practiceHours, location, googleMaps)
//     tidak kosong; bila semua kosong → return null (R5.3).
//   - Render HANYA sub-field tidak kosong, tanpa placeholder (R5.6).
//   - Bila googleMaps kosong tapi sub-field lain ada: section tetap tampil
//     dengan indikasi peta tidak tersedia (R3.14).
//   - Iframe Maps punya title tidak kosong (accessible name) (R11.6).
// Gaya Bloom & Bone: blok kontak ber-ikon + peta berbingkai, ditutup band
// ajakan gelap (arang) dengan tombol pil terakota. CTA WhatsApp hanya tampil
// bila nomor valid (R4.4); band tetap menyatu dalam section kontak (tak ada
// slot section baru). Warna via CSS var saja (R6.4).
import { isEmptyText } from '../lib/empty.ts';
import { buildWaUrl, isValidWaNumber } from '../lib/whatsapp.ts';

interface Props {
  practiceHours?: string;
  location?: string;
  googleMaps?: string;
  waNumber?: string;
  waMessage?: string;
}

const { practiceHours, location, googleMaps, waNumber, waMessage } =
  Astro.props;

const hasHours = !isEmptyText(practiceHours);
const hasLocation = !isEmptyText(location);
const hasMaps = !isEmptyText(googleMaps);

if (!hasHours && !hasLocation && !hasMaps) return null;

// Sub-field non-maps menentukan apakah indikasi "peta tidak tersedia"
// ditampilkan (hanya bila ada konteks kontak lain namun maps kosong, R3.14).
const showMapUnavailable = !hasMaps && (hasHours || hasLocation);

const waValid = isValidWaNumber(waNumber ?? '');
const waHref = waValid ? buildWaUrl(waNumber as string, waMessage) : '';
---

<section class="contact" aria-labelledby="contact-h">
  <div class="container">
    <div class="contact-card">
      <div class="contact-grid">
        <div class="contact-info">
          <span class="kicker">Kontak</span>
          <h2 id="contact-h" class="contact-title" data-reveal style="animation-delay:.20s">Kontak &amp; Lokasi</h2>
          {
            hasHours && (
              <div class="contact-block">
                <span class="contact-ic" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M12 7v5l3 2" />
                  </svg>
                </span>
                <div>
                  <h3 class="contact-label">Jam Praktik</h3>
                  <p class="contact-value">{practiceHours}</p>
                </div>
              </div>
            )
          }
          {
            hasLocation && (
              <div class="contact-block">
                <span class="contact-ic" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z" />
                    <circle cx="12" cy="10" r="2.5" />
                  </svg>
                </span>
                <div>
                  <h3 class="contact-label">Area Layanan</h3>
                  <p class="contact-value">{location}</p>
                </div>
              </div>
            )
          }
          {
            showMapUnavailable && (
              <p class="map-unavailable">Peta lokasi tidak tersedia saat ini.</p>
            )
          }
        </div>
        {
          hasMaps && (
            <div class="contact-map">
              <iframe
                src={googleMaps}
                title="Peta lokasi praktik"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              />
            </div>
          )
        }
      </div>
    </div>

    <div class="cta-band">
      <h2 class="cta-title">Siap memulai pendampingan yang tenang?</h2>
      <p class="cta-sub">
        Hubungi kami untuk konsultasi awal — kami bantu menyusun rencana
        perawatan yang sesuai untuk keluarga Anda.
      </p>
      {
        waValid && (
          <a
            class="cta-btn"
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Hubungi kami via WhatsApp"
          >
            Hubungi via WhatsApp
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .contact-card {
    background: var(--card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: clamp(2rem, 5vw, 4rem);
    box-shadow: var(--shadow);
  }
  .contact-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .contact-title {
    font-size: clamp(1.85rem, 4.5vw, 2.5rem);
    font-weight: 400;
    margin: 0 0 2rem;
  }
  .contact-block {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .contact-block:last-of-type {
    margin-bottom: 0;
  }
  .contact-ic {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), background 0.2s ease, color 0.2s ease;
  }
  .contact-block:hover .contact-ic {
    transform: scale(1.08) rotate(5deg);
    background: var(--accent);
    color: var(--on-accent);
  }
  .contact-label {
    font-size: 1.08rem;
    font-family: var(--font-display);
    font-weight: 450;
    color: var(--ink);
    margin: 0 0 0.25rem;
  }
  .contact-value {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.6;
  }
  .map-unavailable {
    color: var(--ink-soft);
    font-style: italic;
  }
  .contact-map {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    border: 1px solid var(--hairline);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .contact-map:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .contact-map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Band ajakan gelap — penutup dramatis ala Bloom & Bone. */
  .cta-band {
    margin-top: 1.5rem;
    background: var(--ink);
    color: var(--on-ink);
    border-radius: var(--radius-lg);
    padding: clamp(3rem, 6vw, 4.5rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--hairline-dark);
  }
  .cta-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.1;
    margin: 0;
    max-width: 20ch;
  }
  .cta-sub {
    margin: 0;
    color: color-mix(in srgb, var(--on-ink) 76%, transparent);
    max-width: 48ch;
    font-size: 1.05rem;
    line-height: 1.65;
  }
  .cta-btn {
    margin-top: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0.95rem 2.25rem;
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: var(--on-accent);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.96rem;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
      background 0.2s ease;
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    background: color-mix(in srgb, var(--accent) 92%, black);
  }
</style>
