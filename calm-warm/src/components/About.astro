---
// components/About.astro — section 4, Auto-Hide (R3.7, R5.3).
//
// Guard: about kosong (whitespace-only termasuk) → return null (R5.3).
// Warna via CSS var saja (R6.4). Konten about bisa multi-paragraf: pisah
// per baris kosong agar terbaca.
//
// Gaya Bloom & Bone: kartu krem "tanpa beban" berdampingan dengan kartu
// pull-quote sage. Quote bersifat OPSIONAL & dekoratif — diambil dari
// testimonial pertama bila ada; bila tidak, kartu sage tetap menampilkan
// ringkasan janji layanan (tanpa placeholder kosong, R5.6). Auto-Hide section
// tetap hanya bergantung pada `text` (R3.7) — quote tak memengaruhi visibilitas.
import { isEmptyText } from '../lib/empty.ts';
import type { Testimonial } from '../types.ts';

interface Props {
  text?: string;
  quote?: Testimonial;
}

const { text, quote } = Astro.props;
if (isEmptyText(text)) return null;
const paragraphs = (text as string)
  .trim()
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter((p) => p.length > 0);

const hasQuote = !!quote && !isEmptyText(quote.text);
const lead = paragraphs[0];
const rest = paragraphs.slice(1);
---

<section class="about" aria-labelledby="about-h">
  <div class="container about-grid">
    <div class="about-card">
      <span class="kicker">Tentang Kami</span>
      <h2 id="about-h" class="about-title" data-reveal style="animation-delay:.12s">Tak perlu khawatir sendirian</h2>
      <p class="about-lead">{lead}</p>
      {rest.length > 0 && (
        <div class="about-rows">
          {rest.map((p) => <p class="about-p">{p}</p>)}
        </div>
      )}
    </div>

    <aside class="about-quote">
      <span class="quote-icon" aria-hidden="true">&ldquo;</span>
      <div class="quote-content">
        {
          hasQuote ? (
            <>
              <blockquote class="about-quote-text">
                {quote!.text}
              </blockquote>
              <p class="about-quote-by">
                {quote!.name}
                {quote!.role && <span> &mdash; {quote!.role}</span>}
              </p>
            </>
          ) : (
            <>
              <blockquote class="about-quote-text">
                Setiap kunjungan kami rancang dengan tenang, hormat, dan penuh
                perhatian pada hal-hal kecil yang berarti.
              </blockquote>
              <p class="about-quote-by">Janji perawatan kami</p>
            </>
          )
        }
      </div>
    </aside>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    gap: 1.5rem;
    align-items: stretch;
  }
  @media (min-width: 860px) {
    .about-grid {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }
  .about-card {
    background: var(--card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: clamp(2rem, 5vw, 4rem);
    box-shadow: var(--shadow);
  }
  .about-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.85rem, 4.5vw, 2.75rem);
    line-height: 1.1;
    margin: 0 0 1.5rem;
  }
  .about-lead {
    color: var(--ink);
    font-size: clamp(1.08rem, 2vw, 1.25rem);
    line-height: 1.7;
    margin: 0;
    font-weight: 500;
  }
  .about-rows {
    margin-top: 1.75rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--hairline);
    display: grid;
    gap: 1rem;
  }
  .about-p {
    color: var(--ink-soft);
    margin: 0;
    font-size: 1rem;
    line-height: 1.75;
  }
  .about-quote {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--sage);
    color: var(--on-sage);
    border-radius: 24px 80px 24px 80px;
    padding: clamp(2rem, 5vw, 3.5rem);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .quote-icon {
    position: absolute;
    top: -1rem;
    left: 1.5rem;
    font-family: var(--font-display);
    font-size: 8rem;
    line-height: 1;
    color: color-mix(in srgb, var(--on-sage) 12%, transparent);
    user-select: none;
    pointer-events: none;
  }
  .quote-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    gap: 2rem;
  }
  .about-quote-text {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.38rem, 2.5vw, 1.8rem);
    line-height: 1.4;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .about-quote-by {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--on-sage) 82%, transparent);
  }
</style>
