---
// components/HowItWorks.astro — section 6, Auto-Hide (R3.9, R3.12, R5.3).
//
// Guard: howItWorks kosong → return null (R5.3). Render SELURUH entri terurut
// sesuai urutan pada data (Property 8). Gaya Bloom & Bone: langkah bernomor
// editorial dalam grid bergaris, angka serif besar. Warna via CSS var saja
// (R6.4).
import type { HowItWorksStep } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  steps?: HowItWorksStep[];
}

const { steps } = Astro.props;
if (isEmptyList(steps)) return null;
const howItWorks = steps as HowItWorksStep[];
---

<section class="how" aria-labelledby="how-h">
  <div class="container">
    <div class="how-head">
      <span class="kicker">Cara Kerja</span>
      <h2 id="how-h" class="section-title">Mulai dengan tenang</h2>
    </div>
    <ol class="how-list">
      {
        howItWorks.map((s) => (
          <li class="how-step">
            <span class="how-num" aria-hidden="true">
              {s.step}
            </span>
            <div class="how-body">
              <h3 class="how-title">{s.title}</h3>
              <p class="how-desc">{s.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how-head {
    margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
  }
  .how-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    border-top: 1px solid var(--hairline);
  }
  .how-step {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.6rem 1.4rem 1.6rem 0;
    border-bottom: 1px solid var(--hairline);
  }
  .how-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--accent-soft);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.25rem;
  }
  .how-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.25rem;
  }
  .how-desc {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  @media (min-width: 640px) {
    .how-step {
      padding-inline: clamp(1rem, 2vw, 1.75rem);
      border-right: 1px solid var(--hairline);
    }
    .how-step:first-child {
      padding-left: 0;
    }
  }
</style>
