---
// components/HowItWorks.astro — section 6, Auto-Hide (R3.9, R3.12, R5.3).
//
// Guard: howItWorks kosong → return null (R5.3). Render SELURUH entri terurut
// sesuai urutan pada data (Property 8). Gaya Bloom & Bone: langkah bernomor
// editorial dalam grid bergaris, angka serif besar. Warna via CSS var saja
// (R6.4).
import type { HowItWorksStep } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  steps?: HowItWorksStep[];
}

const { steps } = Astro.props;
if (isEmptyList(steps)) return null;
const howItWorks = steps as HowItWorksStep[];
---

<section class="how" aria-labelledby="how-h">
  <div class="container">
    <div class="how-head">
      <span class="kicker">Cara Kerja</span>
      <h2 id="how-h" class="section-title" data-reveal style="animation-delay:.15s">Mulai dengan tenang</h2>
    </div>
    <ol class="how-list">
      {
        howItWorks.map((s) => (
          <li class="how-step">
            <span class="how-num" aria-hidden="true">
              {s.step}
            </span>
            <div class="how-body">
              <h3 class="how-title">{s.title}</h3>
              <p class="how-desc">{s.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how-head {
    margin-bottom: clamp(2.25rem, 4vw, 3.5rem);
  }
  .how-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }
  .how-step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    padding: 2.25rem 2rem;
    background: var(--card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .how-step:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: var(--hairline-strong);
  }
  .how-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background: var(--accent-soft);
    border: 1px solid color-mix(in srgb, var(--accent) 24%, transparent);
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.35rem;
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }
  .how-step:hover .how-num {
    background: var(--accent);
    color: var(--on-accent);
    transform: scale(1.05);
  }
  .how-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--ink);
    line-height: 1.25;
  }
  .how-desc {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.65;
  }
</style>
