---
// components/TrustBar.astro — section 2, Auto-Hide (R3.5, R3.12, R5.3).
//
// Guard: bila credentials kosong → return null (tidak emit elemen/heading/
// container apa pun) (R5.3). Bila ada, render SELURUH entri (Property 8).
// Gaya calm-warm minimalis: strip kredensial STATIS sejajar container, latar
// paper hangat dengan hairline tipis atas-bawah. Tiap kredensial memakai SATU
// ikon "verified" SVG seragam dalam lingkaran sage lembut (lebih rapi & premium
// daripada emoji yang rendering-nya beda antar platform). Separator garis
// vertikal tipis di antar-item, sembunyi saat wrap di mobile. Reveal bertahap
// saat load, dihormati prefers-reduced-motion. Warna via CSS var saja (R6.4).
import type { Credential } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  items?: Credential[];
}

const { items } = Astro.props;
if (isEmptyList(items)) return null;
const credentials = items as Credential[];
---

<section class="trustbar" aria-labelledby="trustbar-h">
  <h2 id="trustbar-h" class="visually-hidden">Kredensial &amp; Sertifikasi</h2>
  <div class="container">
    <ul class="trust-list" role="list">
      {
        credentials.map((c, i) => (
          <li class="trust-item" style={`--i:${i}`}>
            <span class="trust-mark" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5" />
              </svg>
            </span>
            <span class="trust-label">{c.label}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .trustbar {
    padding-block: clamp(1.6rem, 3.5vw, 2.2rem);
    background: var(--paper-2);
    border-block: 1px solid var(--hairline);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .trust-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(1.2rem, 3vw, 2.5rem);
  }
  .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    position: relative;
    opacity: 0;
    transform: translateY(6px);
    animation: trust-in 0.5s ease forwards;
    animation-delay: calc(var(--i) * 80ms);
    transition: transform 0.25s ease;
  }
  .trust-item:hover {
    transform: translateY(-2px);
  }
  .trust-item + .trust-item::before {
    content: '';
    position: absolute;
    left: calc(clamp(1.2rem, 3vw, 2.5rem) / -2);
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 1.2rem;
    background: var(--hairline-strong);
  }
  .trust-mark {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--sage-tint);
    color: var(--sage-deep);
    border: 1px solid color-mix(in srgb, var(--sage-deep) 12%, transparent);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .trust-item:hover .trust-mark {
    background: var(--sage);
    color: var(--on-sage);
    transform: scale(1.05);
  }
  .trust-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(0.84rem, 1.6vw, 0.96rem);
    letter-spacing: 0.015em;
    color: var(--ink);
    white-space: nowrap;
  }
  @keyframes trust-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (max-width: 640px) {
    .trust-list {
      justify-content: flex-start;
    }
    .trust-item + .trust-item::before {
      display: none;
    }
  }
  /* Catatan: guard prefers-reduced-motion sengaja DILEPAS atas permintaan —
     reveal fade-in tetap berjalan meski OS/user meminta reduce-motion. */

</style>
