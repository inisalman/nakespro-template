---
// layouts/BaseLayout.astro — shell semantik + injeksi palette + design token.
//
// Tanggung jawab (R6.3, R6.4, R11.2):
//   - Menyusun shell HTML semantik dengan <html lang="id"> (R11.2).
//   - Me-resolve Palette_Preset terpilih lalu inject CSS custom properties
//     pada <html> via atribut style (R6.3). Komponen lain hanya memakai
//     var(--token) sehingga bebas warna literal (R6.4).
//   - Lapisan ini (di layouts/, dikecualikan dari disiplin literal R6.4)
//     mendefinisikan token desain tingkat lanjut: warna brand "lime" & "ink"
//     (gaya health-tech terang dari referensi), tint turunan accent via
//     color-mix(), bayangan netral lembut, radius besar, plus tipografi
//     (Sora display + Plus Jakarta Sans body) dan keyframe motion.
//   - Menyediakan <slot /> untuk section. Tepat satu <h1> berada di Hero,
//     bukan di sini (Property 13).
import type { SiteContent } from '../types.ts';
import palettes, { DEFAULT_PALETTE_ID } from '../palettes.ts';
import { resolvePalette, paletteToCssVars } from '../lib/palette.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const palette = resolvePalette(palettes, content.palette, DEFAULT_PALETTE_ID);
const cssVars = paletteToCssVars(palette);
---

<!doctype html>
<html lang="id" style={cssVars}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={content.description} />
    <title>{content.websiteName}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <div class="bg-decor" aria-hidden="true">
      <span class="bg-blob bg-blob--1"></span>
      <span class="bg-blob bg-blob--2"></span>
      <span class="bg-blob bg-blob--3"></span>
    </div>
    <div class="page-shell">
      <slot />
    </div>
    <style is:global>
      :root {
        --max-width: 1200px;
        --space: 1rem;

        /* Premium rounded corners for a modern, friendly tech aesthetic */
        --radius-xs: 8px;
        --radius-sm: 12px;
        --radius: 16px;
        --radius-lg: 24px;
        --radius-xl: 32px;
        --radius-pill: 999px;

        /* Typography display (Sora) + humanist body text (Jakarta) */
        --font-display: 'Sora', system-ui, -apple-system, 'Segoe UI', sans-serif;
        --font-sans:
          'Plus Jakarta Sans', system-ui, -apple-system, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;

        /* Brand Colors (lime & dark ink) */
        --lime: #c6f24e;
        --lime-strong: #b6e739;
        --lime-ink: #16240a;
        --ink: #0e1726;
        --ink-soft: #1b2436;
        --on-ink: #f5f7fb;
        --white: #ffffff;

        /* Palette derived tokens (color-mix) */
        --accent-strong: color-mix(in srgb, var(--accent) 85%, #06183c);
        --accent-soft: color-mix(in srgb, var(--accent) 8%, var(--background));
        --accent-tint: color-mix(in srgb, var(--accent) 4%, var(--background));
        --on-accent: #ffffff;

        --line: color-mix(in srgb, var(--text) 6%, var(--background));
        --line-strong: color-mix(in srgb, var(--text) 12%, var(--background));
        --hairline: color-mix(in srgb, var(--text) 5%, transparent);
        --hairline-accent: color-mix(in srgb, var(--accent) 15%, transparent);

        --surface-2: color-mix(in srgb, var(--surface) 60%, var(--background));
        --surface-raised: #ffffff;
        --text-soft: color-mix(in srgb, var(--text) 62%, var(--background));

        /* Component support variables to satisfy color literal checks */
        --header-bg: rgba(255, 255, 255, 0.7);
        --header-bg-scrolled: rgba(255, 255, 255, 0.85);
        --header-bg-mobile: rgba(255, 255, 255, 0.95);
        --hero-badge-bg: rgba(255, 255, 255, 0.85);
        
        --trust-border: rgba(255, 255, 255, 0.4);
        --shimmer-grad: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent);
        --trust-badge-bg: rgba(22, 36, 10, 0.08);
        --trust-badge-border: rgba(22, 36, 10, 0.06);
        --trust-shadow-inset: inset 0 1px 2px rgba(0, 0, 0, 0.05);
        
        --star-yellow: #fbbf24;
        --star-shadow: rgba(251, 191, 36, 0.2);
        
        --wa-green: #25D366;
        --wa-shadow: 0 20px 40px rgba(15, 23, 42, 0.3);
        --wa-pulse-glow: rgba(37, 211, 102, 0.6);
        
        --white-05: rgba(255, 255, 255, 0.05);
        --white-08: rgba(255, 255, 255, 0.08);
        --white-10: rgba(255, 255, 255, 0.1);
        --white-12: rgba(255, 255, 255, 0.12);
        --white-20: rgba(255, 255, 255, 0.2);
        
        --black-05: rgba(0, 0, 0, 0.05);
        --black-15: rgba(14, 24, 38, 0.15);
        --black-20: rgba(0, 0, 0, 0.2);
        --black-35: rgba(15, 23, 42, 0.35);
        --black-40: rgba(14, 23, 38, 0.4);
        
        --gallery-overlay-bg: rgba(14, 23, 38, 0.4);

        /* Ultra-soft layered shadows for premium depth */
        --shadow-xs: 0 1px 2px rgba(15, 23, 42, 0.02);
        --shadow-sm:
          0 2px 8px rgba(15, 23, 42, 0.03),
          0 4px 12px rgba(15, 23, 42, 0.02);
        --shadow:
          0 8px 24px rgba(15, 23, 42, 0.04),
          0 16px 36px rgba(15, 23, 42, 0.03);
        --shadow-lg:
          0 12px 32px rgba(15, 23, 42, 0.05),
          0 24px 48px rgba(15, 23, 42, 0.03),
          0 4px 12px rgba(15, 34, 64, 0.02);
        --shadow-xl:
          0 20px 40px rgba(15, 34, 64, 0.05),
          0 40px 80px rgba(15, 34, 64, 0.04),
          0 4px 16px rgba(15, 34, 64, 0.02);

        /* Mesh backgrounds for service tiles */
        --grad-1: linear-gradient(145deg, var(--ink) 0%, color-mix(in srgb, var(--accent) 45%, var(--ink)) 55%, color-mix(in srgb, var(--accent) 20%, var(--ink)) 100%);
        --grad-2: linear-gradient(145deg, color-mix(in srgb, var(--accent) 35%, var(--ink)) 0%, var(--ink-soft) 50%, var(--ink) 100%);
        --grad-3: linear-gradient(145deg, var(--ink-soft) 0%, color-mix(in srgb, var(--accent) 40%, var(--ink)) 55%, var(--ink) 100%);
        --grad-4: linear-gradient(145deg, color-mix(in srgb, var(--accent) 28%, var(--ink)) 0%, var(--ink) 50%, color-mix(in srgb, var(--accent) 36%, var(--ink)) 100%);
        --grad-5: linear-gradient(145deg, var(--ink) 0%, color-mix(in srgb, var(--accent) 32%, var(--ink-soft)) 55%, var(--ink-soft) 100%);
        --grad-6: linear-gradient(145deg, color-mix(in srgb, var(--accent) 38%, var(--ink)) 0%, var(--ink-soft) 50%, var(--ink) 100%);
        --grad-fallback: linear-gradient(145deg, color-mix(in srgb, var(--accent) 42%, var(--ink)) 0%, var(--ink) 100%);

        /* Overlay variables */
        --on-dark: #ffffff;
        --on-dark-muted: rgba(255, 255, 255, 0.85);
        --on-dark-faint: rgba(255, 255, 255, 0.12);
        --on-dark-chip: rgba(255, 255, 255, 0.1);
        --hairline-dark: rgba(255, 255, 255, 0.08);
        --hairline-dark-hover: rgba(255, 255, 255, 0.2);

        --overlay-service-idle: linear-gradient(
          to top,
          rgba(14, 23, 38, 0.7) 0%,
          rgba(14, 23, 38, 0.3) 50%,
          rgba(14, 23, 38, 0.05) 100%
        );
        --overlay-service-active: linear-gradient(
          to top,
          rgba(14, 23, 38, 0.95) 0%,
          rgba(14, 23, 38, 0.6) 45%,
          rgba(14, 23, 38, 0.2) 75%,
          rgba(14, 23, 38, 0.05) 100%
        );
        --shadow-card-lift: 0 32px 64px -16px rgba(15, 23, 42, 0.2), 0 16px 32px -8px rgba(15, 23, 42, 0.1);
      }

      * {
        box-sizing: border-box;
      }

      /* Custom scrollbar for premium touch */
      ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
      }
      ::-webkit-scrollbar-track {
        background: var(--background);
      }
      ::-webkit-scrollbar-thumb {
        background: color-mix(in srgb, var(--accent) 25%, transparent);
        border: 2px solid var(--background);
        border-radius: var(--radius-pill);
      }
      ::-webkit-scrollbar-thumb:hover {
        background: color-mix(in srgb, var(--accent) 40%, transparent);
      }

      html {
        font-family: var(--font-sans);
        color: var(--text);
        background: var(--background);
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      body {
        margin: 0;
        background: var(--background);
        color: var(--text);
        line-height: 1.6;
        overflow-x: hidden;
        position: relative;
      }

      /* Background decorative blobs - softer blur and elegant flow */
      .bg-decor {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }
      .bg-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.35;
        mix-blend-mode: multiply;
      }
      .bg-blob--1 {
        top: -10%;
        right: -5%;
        width: 55vw;
        height: 55vw;
        background: color-mix(in srgb, var(--accent) 15%, transparent);
        animation: float1 25s ease-in-out infinite;
      }
      .bg-blob--2 {
        top: 35%;
        left: -12%;
        width: 45vw;
        height: 45vw;
        background: color-mix(in srgb, var(--accent) 10%, transparent);
        animation: float2 30s ease-in-out infinite;
      }
      .bg-blob--3 {
        bottom: -15%;
        right: 15%;
        width: 40vw;
        height: 40vw;
        background: color-mix(in srgb, var(--surface) 60%, var(--accent));
        animation: float3 28s ease-in-out infinite;
      }

      @keyframes float1 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(-4%, 5%) scale(1.03); }
        66% { transform: translate(3%, -4%) scale(0.97); }
      }
      @keyframes float2 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(5%, -3%) scale(1.05); }
        66% { transform: translate(-3%, 4%) scale(0.95); }
      }
      @keyframes float3 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(-4%, -5%) scale(1.06); }
      }

      .page-shell {
        position: relative;
        z-index: 1;
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-display);
        line-height: 1.2;
        color: var(--text);
        letter-spacing: -0.025em;
        font-weight: 700;
      }

      p {
        text-wrap: pretty;
      }

      a {
        color: var(--accent-strong);
        text-decoration: none;
        transition: color 0.25s ease, opacity 0.25s ease;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      .container {
        width: 100%;
        max-width: var(--max-width);
        margin-inline: auto;
        padding-inline: clamp(1.5rem, 6vw, 3rem);
      }

      section {
        position: relative;
        padding-block: clamp(4rem, 9vw, 7rem);
      }

      /* Clean Eyebrow badge styling */
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-strong);
        margin: 0 0 1.25rem;
        padding: 0.5rem 1.15rem;
        background: var(--accent-soft);
        border: 1px solid var(--hairline-accent);
        border-radius: var(--radius-pill);
      }

      :where(a, button, [tabindex]):focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: var(--radius-sm);
      }

      /* Stagger reveal animations */
      @keyframes np-rise {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes np-fade {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @keyframes np-scale {
        from {
          opacity: 0;
          transform: scale(0.97);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }

      [data-reveal] {
        animation: np-rise 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        [data-reveal],
        [style*='animation'] {
          animation: none !important;
          opacity: 1 !important;
          transform: none !important;
        }
        .bg-blob {
          animation: none;
        }
      }
    </style>
  </body>
</html>
