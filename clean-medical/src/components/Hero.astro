---
// components/Hero.astro — section 1, selalu render (R5.5), tidak Auto-Hide.
//
// Menampilkan (R3.3, R11.2, R11.4):
//   - Tepat satu <h1> halaman (websiteName) → struktur heading (Property 13).
//   - Tagline opsional sebagai sub-judul.
//   - Foto utama dari content.heroPhoto dengan width/height eksplisit +
//     fetchpriority high (above-the-fold, tidak lazy) (R3.3, R10.8, Property 14).
//   - WhatsApp_CTA above-the-fold dengan accessible name tidak kosong (R3.3,
//     R3.4, R11.4). CTA selalu tampil di Hero (berbeda dari floating yang
//     hilang bila invalid); href tetap dibangun dari nomor.
// Warna hanya via CSS var (R6.4).
import type { SiteContent } from '../types.ts';
import { buildWaUrl, isValidWaNumber } from '../lib/whatsapp.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const heroPhoto = content.heroPhoto;
const heroAlt = heroPhoto
  ? resolveAltText(heroPhoto)
  : `Foto ${content.websiteName}`;
const heroSrc = heroPhoto ? `/images/${heroPhoto.url}` : undefined;
const badges = (content.credentials || []).slice(0, 3);
const waValid = isValidWaNumber(content.waNumber);
const waHref = buildWaUrl(content.waNumber, content.waMessage);
---

<section class="hero" aria-labelledby="hero-h">
  <div class="container">
    <div class="hero-card">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow" data-reveal style="animation-delay:.05s">
            Fisioterapi Homecare
          </p>
          <h1 id="hero-h" data-reveal style="animation-delay:.12s">
            {content.websiteName}
          </h1>
          {
            content.tagline && (
              <p class="hero-tagline" data-reveal style="animation-delay:.2s">
                {content.tagline}
              </p>
            )
          }
          <p class="hero-desc" data-reveal style="animation-delay:.28s">
            {content.description}
          </p>
          {
            waValid && (
              <a
                class="hero-cta"
                href={waHref}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Hubungi kami via WhatsApp"
                data-reveal
                style="animation-delay:.36s"
              >
                <span>Mulai konsultasi</span>
                <span class="hero-cta-ico" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
              </a>
            )
          }
        </div>
        {
          heroSrc && (
            <div class="hero-media" data-reveal style="animation-delay:.24s">
              <span class="hero-blob" aria-hidden="true" />
              <span class="hero-plus" aria-hidden="true">+</span>
              <div class="hero-frame">
                <img
                  src={heroSrc}
                  alt={heroAlt}
                  width="640"
                  height="560"
                  decoding="async"
                  fetchpriority="high"
                />
              </div>
            <ul class="hero-badges" aria-label="Kredensial">
            {badges.map((b, i) => (
              <li class={`hero-badge-item hero-badge-item--${i + 1}`}>
                <span class="hero-badge-ico" aria-hidden="true">{b.icon}</span>
                <span class="hero-badge-txt">{b.label}</span>
              </li>
            ))}
          </ul>
          
            </div>
          )
        }
      </div>
    </div>

    <div class="hero-strip" data-reveal style="animation-delay:.5s">
      <div class="strip-lead">
        <p class="strip-title">Jembatan menuju pemulihan Anda</p>
        <p class="strip-sub">Mulai perjalanan terapi hari ini</p>
      </div>
      <div class="strip-stat">
        <span class="strip-num">12K+</span>
        <span class="strip-label">sesi terapi selesai</span>
      </div>
      <div class="strip-stat">
        <span class="strip-ring" aria-hidden="true">98%</span>
        <span class="strip-label">tingkat pemulihan</span>
      </div>
    </div>
  </div>
</section>

<style>

  @keyframes fsu {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fi {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes bp {
    from { opacity: 0; transform: scale(0.8) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes bf {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .hero {
    background: var(--background);
    padding-block: clamp(1.5rem, 4vw, 2.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .hero-card {
    position: relative;
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: clamp(1.75rem, 4vw, 3.25rem);
    overflow: hidden;
  }
  .hero-grid {
    position: relative;
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  .hero-copy h1 {
    font-size: clamp(2.3rem, 6vw, 4rem);
    margin: 0 0 0.75rem;
    font-weight: 800;
  }
  .hero-tagline {
    font-size: clamp(1.1rem, 2.4vw, 1.45rem);
    color: var(--accent);
    font-weight: 700;
    margin: 0 0 0.85rem;
    line-height: 1.3;
  }
  .hero-desc {
    color: var(--text-soft);
    font-size: clamp(0.98rem, 1.3vw, 1.08rem);
    margin: 0 0 1.75rem;
    max-width: 48ch;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    min-height: 52px;
    padding: 0 0.5rem 0 1.5rem;
    border-radius: var(--radius-pill);
    background: var(--ink);
    color: var(--on-ink);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), background 0.25s ease;
  }
  .hero-cta-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--lime);
    color: var(--lime-ink);
    transition: transform 0.25s ease;
  }
  .hero-cta:hover {
    transform: translateY(-2px);
    background: var(--ink-soft);
  }
  .hero-cta:hover .hero-cta-ico {
    transform: translateX(3px);
  }

  .hero-media {
    position: relative;
    display: flex;
    justify-content: center;
  
    animation: fi .8s ease both;
    animation-delay: .2s;
  }
  .hero-blob {
    position: absolute;
    inset: 8% 4% 0 8%;
    background: var(--accent-soft);
    border-radius: 42% 58% 56% 44% / 48% 42% 58% 52%;
    z-index: 0;
  }
  .hero-plus {
    position: absolute;
    top: 4%;
    right: 12%;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2.25rem;
    color: var(--accent);
    z-index: 2;
    line-height: 1;
  }
  .hero-frame {
    position: relative;
    z-index: 1;
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: var(--surface-raised);
  }
  .hero-frame img {
    width: 100%;
    height: auto;
    aspect-ratio: 8 / 7;
    object-fit: cover;
  }

  /* Strip statistik di bawah kartu hero, ala referensi. */
  .hero-strip {
    display: grid;
    gap: 1.25rem;
    align-items: center;
    margin-top: clamp(1.25rem, 3vw, 2rem);
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  @media (min-width: 720px) {
    .hero-strip {
      grid-template-columns: 1.6fr 1fr 1fr;
    }
  }
  .strip-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text);
    margin: 0 0 0.2rem;
  }
  .strip-sub {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }
  .strip-stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-left: 1.25rem;
    border-left: 1px solid var(--hairline);
  }
  .strip-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.6rem;
    color: var(--accent);
  }
  .strip-ring {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 3px solid var(--lime);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--text);
  }
  .strip-label {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .hero-title { animation: fsu .6s cubic-bezier(.22,1,.36,1) both; animation-delay: .05s; }
  .kicker,.hero-pill,.eyebrow { animation: fsu .6s cubic-bezier(.22,1,.36,1) both; animation-delay: .12s; }
  .hero-desc { animation: fsu .6s cubic-bezier(.22,1,.36,1) both; animation-delay: .25s; }
  .hero-actions { animation: fsu .6s cubic-bezier(.22,1,.36,1) both; animation-delay: .38s; }
  .hero-badge-item {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .55rem .85rem;
    background: var(--accent-soft);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    box-shadow: var(--shadow-sm);
    font-size: .82rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    pointer-events: auto;
    z-index: 3;
    animation: bp .5s cubic-bezier(.22,1,.36,1) both, bf 4s ease-in-out infinite;
  }
  .hero-badge-item:nth-child(1) { top: 8%; left: -4%; animation-delay: .7s, .7s; }
  .hero-badge-item:nth-child(2) { top: 44%; right: -5%; animation-delay: .95s, 1.4s; }
  .hero-badge-item:nth-child(3) { bottom: 9%; left: 2%; animation-delay: 1.2s, 2.1s; }
  .hero-badge-ico { font-size: 1.05rem; line-height: 1; }
  .hero-badge-txt { }
  .hero-badges {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title,.kicker,.hero-pill,.eyebrow,.hero-desc,.hero-actions,.hero-media,.hero-badge-item {
      animation: none;
    }
  }

</style>
