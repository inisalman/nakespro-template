---
// components/Hero.astro — section 1, selalu render (R5.5), tidak Auto-Hide.
//
// Menampilkan (R3.3, R11.2, R11.4):
//   - Tepat satu <h1> halaman (websiteName) → struktur heading (Property 13).
//   - Tagline opsional sebagai sub-judul.
//   - Foto utama dari content.heroPhoto dengan width/height eksplisit +
//     fetchpriority high (above-the-fold, tidak lazy) (R3.3, R10.8, Property 14).
//   - WhatsApp_CTA above-the-fold dengan accessible name tidak kosong (R3.3,
//     R3.4, R11.4). CTA selalu tampil di Hero (berbeda dari floating yang
//     hilang bila invalid); href tetap dibangun dari nomor.
// Warna hanya via CSS var (R6.4).
import type { SiteContent } from '../types.ts';
import { buildWaUrl, isValidWaNumber } from '../lib/whatsapp.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const heroPhoto = content.heroPhoto;
const heroAlt = heroPhoto
  ? resolveAltText(heroPhoto)
  : `Foto ${content.websiteName}`;
const heroSrc = heroPhoto ? `/images/${heroPhoto.url}` : undefined;
const badges = (content.credentials || []).slice(0, 3);
const waValid = isValidWaNumber(content.waNumber);
const waHref = buildWaUrl(content.waNumber, content.waMessage);
---

<section class="hero" aria-labelledby="hero-h">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-text">
        <div class="hero-badge" data-reveal style="animation-delay:.05s">
          <span class="badge-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </span>
          <span>Fisioterapi Homecare</span>
        </div>

        <h1 id="hero-h" data-reveal style="animation-delay:.12s">
          {content.websiteName}
        </h1>

        {content.tagline && (
          <p class="hero-tagline" data-reveal style="animation-delay:.2s">
            {content.tagline}
          </p>
        )}

        <p class="hero-desc" data-reveal style="animation-delay:.28s">
          {content.description}
        </p>

        {waValid && (
          <div class="hero-actions" data-reveal style="animation-delay:.36s">
            <a
              class="hero-cta"
              href={waHref}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Hubungi kami via WhatsApp"
            >
              <span class="cta-inner">
                <span class="cta-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.117 1.528 5.847L.057 23.882l6.196-1.624A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.359-.214-3.68.965.981-3.595-.234-.369A9.818 9.818 0 1112 21.818z"/>
                  </svg>
                </span>
                <span>Mulai Konsultasi</span>
              </span>
              <span class="cta-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6"/>
                </svg>
              </span>
            </a>

            <div class="hero-stats">
              <div class="stat">
                <span class="stat-num">12K+</span>
                <span class="stat-label">Sesi Terapi</span>
              </div>
              <div class="stat-divider"></div>
              <div class="stat">
                <span class="stat-num">98%</span>
                <span class="stat-label">Pemulihan</span>
              </div>
            </div>
          </div>
        )}
      </div>

      {heroSrc && (
        <div class="hero-visual" data-reveal style="animation-delay:.24s">
          <div class="hero-image-wrap">
            <div class="hero-image-bg"></div>
            <div class="hero-image-frame">
              <img
                src={heroSrc}
                alt={heroAlt}
                width="640"
                height="560"
                decoding="async"
                fetchpriority="high"
              />
            </div>
            {badges.length > 0 && (
              <ul class="hero-badges" aria-label="Kredensial">
                {badges.map((b, i) => (
                  <li class={`badge badge--${i + 1}`}>
                    <span class="badge-icon" aria-hidden="true">{b.icon}</span>
                    <span class="badge-text">{b.label}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3rem, 7vw, 6rem) clamp(4rem, 8vw, 7rem);
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -25%;
    right: -15%;
    width: 65vw;
    height: 65vw;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 12%, transparent) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: center;
    z-index: 1;
  }

  @media (min-width: 992px) {
    .hero-content {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }

  .hero-text {
    max-width: 620px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 1.15rem 0.55rem 0.65rem;
    background: var(--accent-soft);
    border: 1px solid var(--hairline-accent);
    border-radius: var(--radius-pill);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--accent-strong);
    margin-bottom: 1.75rem;
    box-shadow: var(--shadow-xs);
  }

  .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: var(--accent);
    border-radius: 50%;
    color: var(--on-accent);
    box-shadow: 0 2px 6px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  h1 {
    font-size: clamp(2.75rem, 6.5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.25rem;
    letter-spacing: -0.035em;
    color: var(--text);
  }

  .hero-tagline {
    font-size: clamp(1.2rem, 2.5vw, 1.55rem);
    color: var(--accent-strong);
    font-weight: 700;
    margin: 0 0 1.5rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .hero-desc {
    color: var(--text-soft);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    margin: 0 0 2.5rem;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: var(--on-accent);
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    overflow: hidden;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 25%, transparent);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-cta:hover {
    transform: translateY(-4px);
    background: var(--accent-strong);
    box-shadow: 0 16px 36px color-mix(in srgb, var(--accent) 40%, transparent);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.95rem 1.75rem;
  }

  .cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lime);
  }

  .cta-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    background: var(--lime);
    color: var(--lime-ink);
    border-left: 1px solid var(--white-10);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-cta:hover .cta-arrow {
    background: var(--white);
    color: var(--accent-strong);
  }

  .hero-cta:hover .cta-arrow svg {
    transform: translateX(4px);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    background: var(--surface-2);
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.65rem;
    color: var(--accent-strong);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-divider {
    width: 1px;
    height: 38px;
    background: var(--line-strong);
  }

  .hero-visual {
    position: relative;
    justify-self: center;
    width: 100%;
    max-width: 500px;
  }

  @media (min-width: 992px) {
    .hero-visual {
      max-width: none;
    }
  }

  .hero-image-wrap {
    position: relative;
    padding: 1rem;
  }

  .hero-image-bg {
    position: absolute;
    inset: 0%;
    background: radial-gradient(circle, var(--accent-soft) 0%, transparent 70%);
    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
    z-index: 0;
    animation: morphBlob 12s ease-in-out infinite;
  }

  @keyframes morphBlob {
    0%, 100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; transform: rotate(0deg); }
    50% { border-radius: 70% 30% 50% 50% / 50% 60% 40% 60%; transform: rotate(180deg); }
  }

  .hero-image-frame {
    position: relative;
    z-index: 1;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 4px solid var(--white);
    box-shadow: var(--shadow-xl);
    background: var(--white);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-image-frame:hover {
    transform: scale(1.02);
  }

  .hero-image-frame img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3.6;
    object-fit: cover;
  }

  .hero-badges {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.8rem 1.25rem;
    background: var(--hero-badge-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--white);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
    pointer-events: auto;
    animation: floatBadge 6s ease-in-out infinite;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .badge:hover {
    background: var(--white);
    box-shadow: var(--shadow);
    transform: scale(1.05) translateY(-2px);
  }

  .badge--1 {
    top: 5%;
    left: -5%;
    animation-delay: 0s;
  }

  .badge--2 {
    top: 45%;
    right: -8%;
    animation-delay: 2s;
  }

  .badge--3 {
    bottom: 5%;
    left: 2%;
    animation-delay: 4s;
  }

  @keyframes floatBadge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .badge-icon {
    font-size: 1.15rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-badge,
    h1,
    .hero-tagline,
    .hero-desc,
    .hero-actions,
    .hero-visual,
    .badge {
      animation: none;
    }
    .hero-image-bg,
    .badge {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .hero-stats {
      width: 100%;
      justify-content: center;
    }
    .badge {
      display: none;
    }
  }
</style>