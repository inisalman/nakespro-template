---
// components/Testimonials.astro — section 7, Auto-Hide (R3.10, R3.12, R5.3).
//
// Guard: testimonials kosong → return null (R5.3). Render SELURUH entri
// (Property 8). Warna via CSS var saja (R6.4).
import type { Testimonial } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  items?: Testimonial[];
}

const { items } = Astro.props;
if (isEmptyList(items)) return null;
const testimonials = items as Testimonial[];

function initials(name: string): string {
  return name
    .trim()
    .split(/\s+/)
    .slice(0, 2)
    .map((w) => w[0]?.toUpperCase() ?? '')
    .join('');
}
---

<section class="testimonials" aria-labelledby="testimonials-h">
  <div class="testi-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="testi-head">
      <p class="eyebrow">Testimoni</p>
      <h2 id="testimonials-h" data-reveal style="animation-delay:.1s">
        Apa kata mereka tentang layanan kami
      </h2>
      <p class="testi-lead" data-reveal style="animation-delay:.15s">
        Kepercayaan pasien adalah prioritas utama kami.
      </p>
    </div>
    <ul class="testi-grid" role="list">
      {
        testimonials.map((t, i) => (
          <li class="testi-card" data-reveal style={`animation-delay:${0.08 + i * 0.08}s`}>
            <div class="card-stars" aria-label="5 dari 5 bintang">
              {[...Array(5)].map(() => (
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <blockquote class="testi-quote">{t.text}</blockquote>
            <div class="testi-meta">
              <span class="testi-avatar" aria-hidden="true">
                {initials(t.name)}
              </span>
              <span class="testi-meta-text">
                <span class="testi-name">{t.name}</span>
                {t.role && <span class="testi-role">{t.role}</span>}
              </span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .testimonials {
    position: relative;
    background: var(--background);
    overflow: hidden;
  }

  .testi-bg {
    position: absolute;
    top: -10%;
    right: -5%;
    width: 45vw;
    height: 45vw;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 7%, transparent) 0%, transparent 65%);
    pointer-events: none;
  }

  .testi-head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto clamp(3rem, 6vw, 4.5rem);
  }

  .testi-head h2 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    margin: 0 0 1rem;
    color: var(--text);
  }

  .testi-lead {
    color: var(--text-soft);
    margin: 0.75rem 0 0;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .testi-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    position: relative;
    z-index: 1;
  }

  .testi-card {
    position: relative;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: 2.25rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .testi-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .card-stars {
    display: flex;
    gap: 0.25rem;
    color: var(--star-yellow);
    margin-bottom: 1.25rem;
  }

  .card-stars svg {
    filter: drop-shadow(0 2px 4px var(--star-shadow));
  }

  .testi-quote {
    margin: 0 0 2rem;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.75;
    font-style: italic;
    font-weight: 500;
    position: relative;
    flex: 1;
  }

  .testi-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .testi-avatar {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent) 0%, color-mix(in srgb, var(--accent) 70%, var(--ink)) 100%);
    color: var(--on-accent);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    box-shadow: 0 4px 10px color-mix(in srgb, var(--accent) 20%, transparent);
    border: 2px solid var(--white);
  }

  .testi-meta-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .testi-name {
    font-weight: 700;
    color: var(--text);
    font-size: 1rem;
    letter-spacing: -0.015em;
  }

  .testi-role {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-soft);
  }
</style>