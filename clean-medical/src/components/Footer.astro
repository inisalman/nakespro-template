---
// components/Footer.astro — selalu render, dikecualikan dari Auto-Hide (R5.5).
//
// Menampilkan teks kecil "Powered by NakesPro" (R3.15). Warna hanya via CSS
// custom properties hasil palette (R6.4) — tanpa nilai warna literal.
import type { SiteContent } from '../types.ts';

interface Props {
  content?: SiteContent;
}

const { content = { websiteName: 'NakesPro', tagline: '' } as SiteContent } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="logo-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </span>
          <span class="logo-text">{content.websiteName}</span>
        </div>
        <p class="footer-tag">{content.tagline || 'Solusi fisioterapi profesional, langsung ke rumah Anda.'}</p>
        <div class="footer-socials">
          <a href="#" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="#" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" aria-label="YouTube">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
            </svg>
          </a>
        </div>
      </div>
      <nav class="footer-nav" aria-label="Tautan footer">
        <div class="nav-group">
          <h3 class="nav-title">Navigasi</h3>
          <a href="#layanan">Layanan</a>
          <a href="#cara-kerja">Cara Kerja</a>
          <a href="#galeri">Galeri</a>
        </div>
        <div class="nav-group">
          <h3 class="nav-title">Hubungi Kami</h3>
          <a href="#kontak">Detail Kontak</a>
          <a href="#cara-kerja">Prosedur</a>
        </div>
      </nav>
    </div>
    <div class="footer-bottom">
      <p class="powered">Powered by NakesPro</p>
      <p class="copyright">&copy; {new Date().getFullYear()} {content.websiteName}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--ink);
    color: var(--on-ink);
    padding-block: clamp(4rem, 8vw, 6rem) clamp(2rem, 4vw, 3rem);
    overflow: hidden;
    border-top: 1px solid color-mix(in srgb, var(--on-ink) 8%, transparent);
  }

  .footer-glow {
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 12%, transparent) 0%, transparent 60%);
    pointer-events: none;
  }

  .footer-top {
    display: grid;
    gap: 3rem;
    align-items: flex-start;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--on-ink) 8%, transparent);
  }

  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .footer-brand {
    max-width: 400px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: color-mix(in srgb, var(--accent) 20%, transparent);
    border: 1px solid var(--white-10);
    border-radius: var(--radius);
    color: var(--lime);
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.02em;
  }

  .footer-tag {
    margin: 0;
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--on-ink) 70%, transparent);
    line-height: 1.7;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .footer-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--white-05);
    border: 1px solid var(--white-08);
    color: color-mix(in srgb, var(--on-ink) 70%, transparent);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer-socials a:hover {
    background: var(--lime);
    color: var(--lime-ink);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--lime) 20%, transparent);
  }

  .footer-nav {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, 1fr);
  }

  .nav-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--on-ink) 45%, transparent);
    margin: 0 0 0.25rem;
  }

  .footer-nav a {
    color: color-mix(in srgb, var(--on-ink) 75%, transparent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.25s ease;
  }

  .footer-nav a:hover {
    color: var(--lime);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.75rem;
  }

  .powered {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--on-ink) 45%, transparent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .copyright {
    margin: 0;
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--on-ink) 50%, transparent);
  }
</style>