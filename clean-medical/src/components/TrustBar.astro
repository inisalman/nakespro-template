---
// components/TrustBar.astro — section 2, Auto-Hide (R3.5, R3.12, R5.3).
//
// Guard: bila credentials kosong → return null (tidak emit elemen/heading/
// container apa pun) (R5.3). Bila ada, render SELURUH entri (Property 8).
// Warna via CSS var saja (R6.4).
import type { Credential } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  items?: Credential[];
}

const { items } = Astro.props;
if (isEmptyList(items)) return null;
const credentials = items as Credential[];
---

<section class="trustbar" aria-labelledby="trustbar-h">
  <div class="container">
    <h2 id="trustbar-h" class="visually-hidden">Kredensial &amp; Sertifikasi</h2>
    <div class="trust-band">
      <ul class="trust-list" role="list">
        {
          credentials.map((c) => (
            <li class="trust-item">
              {c.icon && (
                <span class="trust-icon" aria-hidden="true">
                  {c.icon}
                </span>
              )}
              <span class="trust-label">{c.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .trustbar {
    background: var(--background);
    padding-block: clamp(1rem, 3vw, 2rem);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .trust-band {
    background: var(--lime);
    border-radius: var(--radius);
    padding: clamp(1rem, 2.5vw, 1.5rem) clamp(1.25rem, 3vw, 2.25rem);
    box-shadow: var(--shadow-sm);
  }
  .trust-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2.5rem;
    align-items: center;
    justify-content: center;
  }
  .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--lime-ink);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
  }
  .trust-icon {
    font-size: 1.2rem;
    line-height: 1;
  }
</style>
