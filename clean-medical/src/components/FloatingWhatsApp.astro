---
// components/FloatingWhatsApp.astro — WhatsApp_CTA mengambang (R4.1, R4.4).
//
// Render hanya bila nomor valid: 8–15 digit setelah normalisasi (R4.4,
// Property 2). Bila kosong/invalid → tidak emit elemen apa pun. Sticky/floating
// agar terlihat di seluruh scroll pada 320–1920px (R4.1, R12.4). URL disusun
// via buildWaUrl (R4.2, R4.3). Accessible name tidak kosong (R11.4).
import { isValidWaNumber, buildWaUrl } from '../lib/whatsapp.ts';

interface Props {
  waNumber: string;
  waMessage?: string;
}

const { waNumber, waMessage } = Astro.props;
const show = isValidWaNumber(waNumber);
const href = show ? buildWaUrl(waNumber, waMessage) : '';
---

{
  show && (
    <a
      class="floating-wa"
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Hubungi kami via WhatsApp"
    >
      <span class="wa-pulse" aria-hidden="true" />
      <span class="wa-badge" aria-hidden="true">
        <svg
          class="wa-icon"
          viewBox="0 0 24 24"
          width="26"
          height="26"
          aria-hidden="true"
          focusable="false"
          fill="currentColor"
        >
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.117 1.528 5.847L.057 23.882l6.196-1.624A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.359-.214-3.68.965.981-3.595-.234-.369A9.818 9.818 0 1112 21.818z"/>
        </svg>
      </span>
      <span class="wa-label">Chat Sekarang</span>
    </a>
  )
}

<style>
  .floating-wa {
    position: fixed;
    right: clamp(1rem, 4vw, 2rem);
    bottom: clamp(1rem, 4vw, 2rem);
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1.25rem 0.5rem 0.5rem;
    border-radius: var(--radius-pill);
    background: var(--ink);
    color: var(--on-ink);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    box-shadow: var(--shadow-xl);
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.25s ease,
      box-shadow 0.3s ease;
  }

  .floating-wa:hover {
    transform: translateY(-4px) scale(1.02);
    background: var(--ink-soft);
    box-shadow: var(--wa-shadow);
  }

  .wa-badge {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--wa-green);
    color: var(--white);
    flex: none;
    transition: transform 0.3s ease;
  }

  .floating-wa:hover .wa-badge {
    transform: scale(1.05);
  }

  .wa-pulse {
    position: absolute;
    left: 0.5rem;
    top: 50%;
    width: 44px;
    height: 44px;
    transform: translateY(-50%);
    border-radius: 50%;
    background: var(--wa-green);
    z-index: 0;
    animation: wa-ping 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes wa-ping {
    0% {
      transform: translateY(-50%) scale(1);
      opacity: 0.6;
    }
    75%, 100% {
      transform: translateY(-50%) scale(1.8);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-pulse {
      animation: none;
      display: none;
    }
  }

  @media (max-width: 480px) {
    .wa-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .floating-wa {
      padding: 0.5rem;
      min-width: 56px;
      justify-content: center;
    }
  }
</style>