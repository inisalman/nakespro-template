---
// components/FloatingWhatsApp.astro — WhatsApp_CTA mengambang (R4.1, R4.4).
//
// Render hanya bila nomor valid: 8–15 digit setelah normalisasi (R4.4,
// Property 2). Bila kosong/invalid → tidak emit elemen apa pun. Sticky/floating
// agar terlihat di seluruh scroll pada 320–1920px (R4.1, R12.4). URL disusun
// via buildWaUrl (R4.2, R4.3). Accessible name tidak kosong (R11.4).
import { isValidWaNumber, buildWaUrl } from '../lib/whatsapp.ts';

interface Props {
  waNumber: string;
  waMessage?: string;
}

const { waNumber, waMessage } = Astro.props;
const show = isValidWaNumber(waNumber);
const href = show ? buildWaUrl(waNumber, waMessage) : '';
---

{
  show && (
    <a
      class="floating-wa"
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Hubungi kami via WhatsApp"
    >
      <span class="wa-pulse" aria-hidden="true" />
      <span class="wa-badge" aria-hidden="true">
        <svg
          class="wa-icon"
          viewBox="0 0 24 24"
          width="26"
          height="26"
          aria-hidden="true"
          focusable="false"
          fill="currentColor"
        >
          <path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.23 8.23 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.83c0 4.54-3.69 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28Z" />
        </svg>
      </span>
      <span class="wa-label">Chat fisioterapis</span>
    </a>
  )
}

<style>
  .floating-wa {
    position: fixed;
    right: clamp(1rem, 4vw, 2rem);
    bottom: clamp(1rem, 4vw, 2rem);
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 56px;
    padding: 0.5rem 1.35rem 0.5rem 0.5rem;
    border-radius: var(--radius-pill);
    background: var(--ink);
    color: var(--on-ink);
    font-weight: 700;
    text-decoration: none;
    box-shadow: var(--shadow-lg);
    transition:
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.25s ease;
  }
  .floating-wa:hover {
    transform: translateY(-2px) scale(1.02);
    background: var(--ink-soft);
  }
  .wa-badge {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--lime);
    color: var(--lime-ink);
    flex: none;
  }
  /* Cincin pulsa lembut untuk menarik perhatian tanpa mengganggu. */
  .wa-pulse {
    position: absolute;
    left: 0.5rem;
    top: 50%;
    width: 44px;
    height: 44px;
    transform: translateY(-50%);
    border-radius: 50%;
    background: var(--lime);
    z-index: 0;
    animation: wa-ping 2.6s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  @keyframes wa-ping {
    0% {
      transform: translateY(-50%) scale(1);
      opacity: 0.5;
    }
    70%,
    100% {
      transform: translateY(-50%) scale(1.6);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-pulse {
      animation: none;
      display: none;
    }
  }
  @media (max-width: 480px) {
    .wa-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .floating-wa {
      padding: 0.5rem;
      min-width: 56px;
      justify-content: center;
    }
  }
</style>
