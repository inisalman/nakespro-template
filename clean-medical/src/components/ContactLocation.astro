---
// components/ContactLocation.astro — section 8, Auto-Hide penuh + partial
// (R3.11, R3.14, R5.3, R5.6, Property 5).
//
// Aturan render:
//   - Section dirender bila ≥1 sub-field (practiceHours, location, googleMaps)
//     tidak kosong; bila semua kosong → return null (R5.3).
//   - Render HANYA sub-field tidak kosong, tanpa placeholder (R5.6).
//   - Bila googleMaps kosong tapi sub-field lain ada: section tetap tampil
//     dengan indikasi peta tidak tersedia (R3.14).
//   - Iframe Maps punya title tidak kosong (accessible name) (R11.6).
// Warna via CSS var saja (R6.4).
import { isEmptyText } from '../lib/empty.ts';

interface Props {
  practiceHours?: string;
  location?: string;
  googleMaps?: string;
}

const { practiceHours, location, googleMaps } = Astro.props;

const hasHours = !isEmptyText(practiceHours);
const hasLocation = !isEmptyText(location);
const hasMaps = !isEmptyText(googleMaps);

if (!hasHours && !hasLocation && !hasMaps) return null;

const showMapUnavailable = !hasMaps && (hasHours || hasLocation);
---

<section class="contact" id="kontak" aria-labelledby="contact-h">
  <div class="contact-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="contact-card" data-reveal style="animation-delay:.1s">
      <div class="contact-grid">
        <div class="contact-info">
          <p class="eyebrow">Hubungi Kami</p>
          <h2 id="contact-h">Siap berkunjung ke rumah Anda</h2>
          <p class="contact-intro">
            Konsultasikan kebutuhan terapi Anda. Tim kami siap memberikan
            layanan terbaik langsung ke lokasi Anda.
          </p>
          {
            hasHours && (
              <div class="contact-block">
                <div class="block-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <div class="block-content">
                  <h3 class="contact-label">Jam Praktik</h3>
                  <p class="contact-value">{practiceHours}</p>
                </div>
              </div>
            )
          }
          {
            hasLocation && (
              <div class="contact-block">
                <div class="block-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div class="block-content">
                  <h3 class="contact-label">Area Layanan</h3>
                  <p class="contact-value">{location}</p>
                </div>
              </div>
            )
          }
          {
            showMapUnavailable && (
              <div class="map-unavailable">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 8v4M12 16h.01"/>
                </svg>
                <span>Peta lokasi tidak tersedia saat ini.</span>
              </div>
            )
          }
        </div>
        {
          hasMaps && (
            <div class="contact-map">
              <iframe
                src={googleMaps}
                title="Peta lokasi praktik"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              />
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    background: var(--surface-2);
    overflow: hidden;
  }

  .contact-bg {
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 55vw;
    height: 55vw;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 6%, transparent) 0%, transparent 65%);
    pointer-events: none;
  }

  .contact-card {
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 5vw, 4rem);
    box-shadow: var(--shadow-xl);
    position: relative;
    z-index: 1;
  }

  .contact-grid {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4rem);
    align-items: stretch;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1.15fr;
    }
  }

  .contact h2 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    margin: 0 0 1.25rem;
    line-height: 1.2;
    color: var(--text);
    letter-spacing: -0.025em;
  }

  .contact-intro {
    color: var(--text-soft);
    margin: 0 0 2.5rem;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .contact-block {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line);
  }

  .contact-block:last-of-type {
    border-bottom: none;
  }

  .block-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius);
    background: var(--accent-soft);
    border: 1px solid var(--hairline-accent);
    color: var(--accent-strong);
    box-shadow: var(--shadow-xs);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-block:hover .block-icon {
    transform: scale(1.05) rotate(5deg);
    background: var(--accent);
    color: var(--on-accent);
  }

  .block-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-strong);
    margin: 0;
  }

  .contact-value {
    margin: 0;
    color: var(--text);
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.5;
  }

  .map-unavailable {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-top: 1.75rem;
    padding: 1.15rem;
    background: var(--accent-soft);
    border: 1px solid var(--hairline-accent);
    border-radius: var(--radius);
    color: var(--text-soft);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .contact-map {
    position: relative;
    width: 100%;
    min-height: 360px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 4px solid var(--white);
    background: var(--surface-2);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-map:hover {
    transform: scale(1.01);
  }

  .contact-map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>