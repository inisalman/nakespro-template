---
// components/HowItWorks.astro — section 6, Auto-Hide (R3.9, R3.12, R5.3).
//
// Guard: howItWorks kosong → return null (R5.3). Render SELURUH entri terurut
// sesuai urutan pada data (Property 8). Warna via CSS var saja (R6.4).
import type { HowItWorksStep } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  steps?: HowItWorksStep[];
}

const { steps } = Astro.props;
if (isEmptyList(steps)) return null;
const howItWorks = steps as HowItWorksStep[];
---

<section class="how" id="cara-kerja" aria-labelledby="how-h">
  <div class="how-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="how-head">
      <p class="eyebrow">Cara Kerja</p>
      <h2 id="how-h" data-reveal style="animation-delay:.1s">Empat langkah mudah menuju solusi Anda</h2>
      <p class="how-lead" data-reveal style="animation-delay:.15s">
        Proses yang transparan dan mudah dipahami untuk memulai perjalanan terapi Anda.
      </p>
    </div>
    <ol class="how-list">
      {
        howItWorks.map((s, i) => (
          <li class="how-step" data-reveal style={`animation-delay:${0.1 + i * 0.08}s`}>
            <div class="step-connector" aria-hidden="true">
              <span class="step-line"></span>
            </div>
            <div class="step-card">
              <span class="how-num" aria-hidden="true">
                {String(s.step).padStart(2, '0')}
              </span>
              <div class="how-body">
                <h3 class="how-title">{s.title}</h3>
                <p class="how-desc">{s.description}</p>
              </div>
              <div class="step-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </div>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how {
    position: relative;
    background: var(--surface-2);
    overflow: hidden;
  }

  .how-bg {
    position: absolute;
    top: -20%;
    left: -10%;
    width: 45vw;
    height: 45vw;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 5%, transparent) 0%, transparent 60%);
    pointer-events: none;
  }

  .how-head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto clamp(3rem, 6vw, 4.5rem);
  }

  .how-head h2 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    margin: 0 0 1rem;
    color: var(--text);
  }

  .how-lead {
    color: var(--text-soft);
    margin: 0.75rem 0 0;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .how-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .how-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .how-list {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
  }

  .how-step {
    position: relative;
  }

  .step-connector {
    display: none;
  }

  @media (min-width: 1024px) {
    .step-connector {
      display: block;
      position: absolute;
      top: 3.25rem;
      right: -0.75rem;
      width: 1.5rem;
      z-index: 2;
    }

    .step-line {
      display: block;
      height: 2px;
      background: linear-gradient(90deg, var(--accent) 0%, color-mix(in srgb, var(--accent) 20%, transparent) 100%);
      position: relative;
    }

    .step-line::after {
      content: '';
      position: absolute;
      right: 0;
      top: -3px;
      width: 8px;
      height: 8px;
      border-top: 2px solid color-mix(in srgb, var(--accent) 60%, transparent);
      border-right: 2px solid color-mix(in srgb, var(--accent) 60%, transparent);
      transform: rotate(45deg);
    }

    .how-step:last-child .step-connector {
      display: none;
    }
  }

  .step-card {
    position: relative;
    padding: 2.25rem 1.75rem 1.75rem;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .step-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .how-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--on-accent);
    background: var(--accent);
    border: 3px solid var(--white);
    border-radius: var(--radius);
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--accent) 25%, transparent);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .step-card:hover .how-num {
    transform: scale(1.08) rotate(-5deg);
    background: var(--accent-strong);
    box-shadow: 0 6px 16px color-mix(in srgb, var(--accent) 45%, transparent);
  }

  .how-body {
    flex: 1;
  }

  .how-title {
    margin: 0 0 0.65rem;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.35;
    letter-spacing: -0.015em;
  }

  .how-desc {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .step-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent-strong);
    margin-top: 1.5rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .step-card:hover .step-arrow {
    background: var(--lime);
    color: var(--lime-ink);
    transform: translateX(6px);
  }
</style>