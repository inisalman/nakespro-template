---
// components/Services.astro — section 3, Auto-Hide (R3.6, R3.12, R5.3).
//
// Guard: services kosong → return null (R5.3). Bila ada, render SELURUH entri
// (Property 8). Warna via var(--token)/color-mix saja (R6.4).
//
// Tile accordion (gaya modern-light): tile tumpuk vertikal di mobile/tablet,
// jadi baris horizontal di layar lebar; satu tile aktif (melebar + reveal
// deskripsi) pada satu waktu via hover/focus/click + keyboard. Latar tiap tile:
// service.image → fallback round-robin dari galeri photos → terakhir mesh biru-
// klinis token (--grad-N). Overlay gelap menjamin keterbacaan teks putih.
//
// Catatan: kelas `has-image` sengaja TIDAK dipakai di kartu — kondisi ada-foto
// ditandai via atribut `data-has-image` agar regex kontrak `class="service-card"`
// tetap akurat (Property 8).
import type { Service, Photo } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  items?: Service[];
  photos?: Photo[];
}

const { items, photos } = Astro.props;
if (isEmptyList(items)) return null;
const services = items as Service[];

// Pool foto galeri sebagai fallback round-robin.
const photoPool: string[] = (photos ?? []).map((p) => p.url).filter(Boolean);

const pad = (n: number) => String(n + 1).padStart(2, '0');
---

<section class="services" id="layanan" aria-labelledby="services-h">
  <div class="services-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="services-head">
      <p class="eyebrow">Layanan Kami</p>
      <h2 id="services-h" data-reveal style="animation-delay:.10s">Solusi Terapi untuk Kebutuhan Anda</h2>
      <p class="services-lead">
        Setiap program disusun dari asesmen menyeluruh menjadi rencana
        terukur, lalu dijalankan langsung di rumah Anda dengan pendekatan personal.
      </p>
    </div>
    <ul class="services-grid" role="list">
      {
        services.map((s, i) => {
          const preferred = s.image;
          const poolBg = photoPool.length > 0 ? photoPool[i % photoPool.length] : null;
          const bg = preferred ? `/images/${preferred}` : (poolBg ? `/images/${poolBg}` : null);
          return (
            <li
              class="service-card"
              data-active={i === 0 ? 'true' : 'false'}
              data-has-image={bg ? '' : undefined}
              tabindex="0"
              role="button"
              aria-expanded={i === 0 ? 'true' : 'false'}
              style={`--i: ${i}${bg ? `; --card-img: url('${bg}')` : ''}`}
            >
              <div class="card-inner">
                <span class="service-num" aria-hidden="true">{pad(i)}</span>
                <div class="service-content">
                  <h3 class="service-title">{s.title}</h3>
                  <div class="service-reveal">
                    <p class="service-desc">{s.description}</p>
                    <span class="service-link">
                      Pelajari layanan
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </span>
                  </div>
                </div>
                <div class="service-indicator" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </div>
              </div>
              <div class="service-progress" aria-hidden="true"></div>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.service-card'));

  if (!prefersReduced && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    cards.forEach((c) => io.observe(c));
  } else {
    cards.forEach((c) => c.classList.add('is-visible'));
  }

  const activate = (target: HTMLElement) => {
    cards.forEach((c) => {
      const on = c === target;
      c.dataset.active = on ? 'true' : 'false';
      c.setAttribute('aria-expanded', on ? 'true' : 'false');
    });
  };

  const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  cards.forEach((card) => {
    if (finePointer) {
      card.addEventListener('mouseenter', () => activate(card));
      card.addEventListener('focus', () => activate(card));
    }
    card.addEventListener('click', () => activate(card));
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activate(card);
      }
    });
  });
</script>

<style>
  .services {
    position: relative;
    background: var(--background);
    overflow: hidden;
  }

  .services-bg {
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 55vw;
    height: 55vw;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }

  .services-head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto clamp(3rem, 6vw, 4.5rem);
  }

  .services-head h2 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    color: var(--text);
  }

  .services-lead {
    color: var(--text-soft);
    margin: 1rem 0 0;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  /* Responsive layout: vertical scroll on mobile/tablet, expandable row on desktop */
  .services-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .services-grid {
      display: flex;
      flex-wrap: nowrap;
      align-items: stretch;
      justify-content: center;
      gap: 1.25rem;
    }
  }

  /* Premium gradient mesh per card */
  .service-card:nth-child(1) { --grad: var(--grad-1); }
  .service-card:nth-child(2) { --grad: var(--grad-2); }
  .service-card:nth-child(3) { --grad: var(--grad-3); }
  .service-card:nth-child(4) { --grad: var(--grad-4); }
  .service-card:nth-child(5) { --grad: var(--grad-5); }
  .service-card:nth-child(6) { --grad: var(--grad-6); }

  /* Card Container */
  .service-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    isolation: isolate;
    background: var(--grad, var(--grad-fallback));
    min-height: 340px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--hairline-dark);
    box-shadow: var(--shadow-sm);
    transition:
      box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      flex-basis 0.6s cubic-bezier(0.16, 1, 0.3, 1);

    /* Scroll reveal: start hidden */
    opacity: 0;
    transform: translateY(32px);
  }

  /* Expandable tiles on desktop screen */
  @media (min-width: 1024px) {
    .service-card {
      flex: 0 0 280px;
      min-height: 520px;
      cursor: pointer;
    }
    .service-card[data-active='true'] {
      flex-basis: 500px;
      border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    }
  }

  @media (min-width: 1280px) {
    .service-card {
      flex-basis: 300px;
      min-height: 580px;
    }
    .service-card[data-active='true'] {
      flex-basis: 540px;
    }
  }

  /* Background image with subtle zoom */
  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--grad, var(--grad-fallback));
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: -2;
  }

  .service-card[data-has-image]::before {
    background-image: var(--card-img);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .service-card[data-active='true']::before {
    transform: scale(1.08);
  }

  /* Double-layer readable overlays */
  .service-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--overlay-service-idle);
    z-index: -1;
    transition: background 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-card[data-active='true']::after {
    background: var(--overlay-service-active);
  }

  /* Stagger delay per card */
  .service-card { transition-delay: calc(var(--i) * 0.05s); }

  .service-card.is-visible {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--i) * 0.08s),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--i) * 0.08s),
      flex-basis 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.6s ease,
      box-shadow 0.6s ease;
  }

  .service-card[data-active='true'].is-visible {
    box-shadow: var(--shadow-card-lift);
  }

  .card-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding: 2.25rem;
  }

  /* Glassmorphism card badge */
  .service-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--on-dark);
    background: var(--white-10);
    border: 1px solid var(--white-12);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-card[data-active='true'] .service-num {
    background: var(--accent);
    border-color: var(--accent-strong);
    color: var(--on-accent);
    transform: scale(1.1);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .service-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .service-title {
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    font-weight: 700;
    margin: 0;
    color: var(--on-dark);
    line-height: 1.25;
    letter-spacing: -0.015em;
    text-shadow: 0 2px 4px var(--black-15);
  }

  /* Smooth slider-reveal for active descriptions */
  .service-reveal {
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 0.85rem;
  }

  @media (min-width: 1024px) {
    .service-reveal {
      display: grid;
      grid-template-rows: 0fr;
      opacity: 0;
      margin-top: 0;
    }
    .service-card[data-active='true'] .service-reveal {
      grid-template-rows: 1fr;
      opacity: 1;
      margin-top: 0.85rem;
    }
  }

  .service-reveal > * {
    min-height: 0;
  }

  .service-desc {
    color: var(--on-dark-muted);
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--lime);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .service-link svg {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-card[data-active='true'] .service-link svg {
    transform: translateX(5px);
  }

  .service-card[data-active='true'] .service-link {
    color: var(--white);
  }

  /* Custom indicator icons */
  .service-indicator {
    position: absolute;
    top: 2rem;
    right: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--white-08);
    border: 1px solid var(--white-10);
    border-radius: 50%;
    color: var(--on-dark);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-card[data-active='true'] .service-indicator {
    background: var(--accent);
    border-color: var(--accent-strong);
    color: var(--on-accent);
    transform: rotate(45deg);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .service-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 5px;
    width: 0;
    background: var(--lime);
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 -2px 10px var(--lime);
  }

  .service-card[data-active='true'] .service-progress {
    width: 100%;
  }

  /* Reduced Motion fallback */
  @media (prefers-reduced-motion: reduce) {
    .service-card {
      opacity: 1;
      transform: none;
      transition: flex-basis 0.3s ease, box-shadow 0.2s;
    }
    .service-card::before,
    .service-card[data-active='true']::before {
      transform: none;
      transition: none;
    }
    .service-reveal {
      transition: opacity 0.2s ease;
    }
    .service-progress {
      transition: width 0.2s ease;
    }
  }
</style>