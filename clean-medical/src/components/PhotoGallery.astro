---
// components/PhotoGallery.astro — section 5, Auto-Hide galeri (R3.8,
// R3.13, R5.3, Property 5/8).
//
// Aturan render:
//   - Section dirender bila ada ≥1 foto; bila galeri kosong → return null
//     (R5.3).
//   - Seluruh foto dirender pada satu grid tunggal, urutan sesuai daftar
//     (R3.13).
//   - Tiap gambar: width/height eksplisit, loading="lazy" (below-the-fold,
//     R10.8 Property 14), format modern (.webp di public/images), alt via
//     resolveAltText (R11.1).
// Warna via CSS var saja (R6.4).
import type { Photo } from '../types.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  photos?: Photo[];
}

const { photos } = Astro.props;

const items = photos ?? [];

if (items.length === 0) return null;
---

<section class="gallery" id="galeri" aria-labelledby="gallery-h">
  <div class="gallery-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="gallery-head">
      <p class="eyebrow">Galeri Kami</p>
      <h2 id="gallery-h" data-reveal style="animation-delay:.1s">Berdedikasi untuk kesejahteraan Anda</h2>
      <p class="gallery-lead" data-reveal style="animation-delay:.15s">
        Dokumentasi kegiatan dan momen berharga bersama pasien kami.
      </p>
    </div>
    <ul class="gallery-grid" role="list">
      {
        items.map((photo, i) => (
          <li class="gallery-item" data-reveal style={`animation-delay:${0.05 * (i + 1)}s`}>
            <div class="gallery-shot">
              <img
                src={`/images/${photo.url}`}
                alt={resolveAltText(photo)}
                width="400"
                height="300"
                loading="lazy"
                decoding="async"
              />
              <div class="gallery-overlay" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"/>
                  <path d="m21 21-4.35-4.35"/>
                  <path d="M11 8v6M8 11h6"/>
                </svg>
              </div>
            </div>
            {photo.caption && (
              <figcaption class="gallery-cap">{photo.caption}</figcaption>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .gallery {
    position: relative;
    background: var(--background);
    overflow: hidden;
  }

  .gallery-bg {
    position: absolute;
    bottom: -30%;
    right: -15%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 6%, transparent) 0%, transparent 65%);
    pointer-events: none;
  }

  .gallery-head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto clamp(3rem, 6vw, 4.5rem);
  }

  .gallery-head h2 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    margin: 0 0 1rem;
    color: var(--text);
  }

  .gallery-lead {
    color: var(--text-soft);
    margin: 0.75rem 0 0;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .gallery-item {
    margin: 0;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .gallery-shot {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--surface-2);
  }

  .gallery-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover .gallery-shot img {
    transform: scale(1.06);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gallery-overlay-bg);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.4s ease;
    color: white;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-overlay svg {
    transform: scale(0.8);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-item:hover .gallery-overlay svg {
    transform: scale(1);
  }

  .gallery-cap {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
    padding: 1.25rem 1.5rem;
    line-height: 1.4;
    border-top: 1px solid var(--line);
    letter-spacing: -0.015em;
  }
</style>