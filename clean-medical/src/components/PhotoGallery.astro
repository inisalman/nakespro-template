---
// components/PhotoGallery.astro — section 5, Auto-Hide per kategori (R3.8,
// R3.13, R5.3, Property 5/8).
//
// Aturan render:
//   - Section dirender bila ada ≥1 foto di kategori mana pun; bila semua
//     kategori kosong → return null (R5.3).
//   - Hanya grup kategori tidak kosong yang dirender; grup kosong disembunyikan
//     (R3.13). Urutan kategori tetap: nakes, ruangan, alat, hasil.
//   - Tiap gambar: width/height eksplisit, loading="lazy" (below-the-fold,
//     R10.8 Property 14), format modern (.webp di public/images), alt via
//     resolveAltText (R11.1).
// Warna via CSS var saja (R6.4).
import type { PhotoSet } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  photos?: PhotoSet;
}

const LABELS: Record<keyof PhotoSet, string> = {
  nakes: 'Tenaga Kesehatan',
  ruangan: 'Ruangan',
  alat: 'Peralatan',
  hasil: 'Hasil',
};
const ORDER: (keyof PhotoSet)[] = ['nakes', 'ruangan', 'alat', 'hasil'];

const { photos } = Astro.props;

const groups = photos
  ? ORDER.filter((cat) => !isEmptyList(photos[cat])).map((cat) => ({
      cat,
      label: LABELS[cat],
      items: photos[cat],
    }))
  : [];

if (groups.length === 0) return null;
---

<section class="gallery" aria-labelledby="gallery-h">
  <div class="container">
    <div class="gallery-head">
      <p class="eyebrow">Galeri Kami</p>
      <h2 id="gallery-h">Berdedikasi untuk kesejahteraan Anda</h2>
    </div>
    {
      groups.map((group) => (
        <div class="gallery-group">
          <h3 class="gallery-cat">{group.label}</h3>
          <ul class="gallery-grid" role="list">
            {group.items.map((photo, i) => (
              <li class="gallery-item" data-reveal style={`animation-delay:${0.05 * i}s`}>
                <div class="gallery-shot">
                  <img
                    src={`/images/${photo.url}`}
                    alt={resolveAltText(photo)}
                    width="400"
                    height="300"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                {photo.caption && (
                  <figcaption class="gallery-cap">{photo.caption}</figcaption>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  .gallery {
    background: var(--surface);
  }
  .gallery-head {
    text-align: center;
    max-width: 36ch;
    margin: 0 auto 2.5rem;
  }
  .gallery-head .eyebrow {
    justify-content: center;
  }
  .gallery h2 {
    font-size: clamp(1.7rem, 3.8vw, 2.6rem);
    margin: 0;
  }
  .gallery-group {
    margin-bottom: 2.25rem;
  }
  .gallery-group:last-child {
    margin-bottom: 0;
  }
  .gallery-cat {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1rem;
  }
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  }
  .gallery-item {
    margin: 0;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.65rem 0.65rem 0.9rem;
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease;
  }
  .gallery-item:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow);
  }
  .gallery-shot {
    position: relative;
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }
  .gallery-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .gallery-item:hover .gallery-shot img {
    transform: scale(1.05);
  }
  .gallery-cap {
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 0.75rem;
    padding-inline: 0.35rem;
  }
</style>
