---
// components/PhotoGallery.astro — section 5, Auto-Hide galeri (R3.8,
// R3.13, R5.3, Property 5/8).
//
// Aturan render:
//   - Section dirender bila ada ≥1 foto; bila galeri kosong → return null
//     (R5.3).
//   - Seluruh foto dirender pada satu grid tunggal, urutan sesuai daftar
//     (R3.13).
//   - Tiap gambar: width/height eksplisit, loading="lazy" (below-the-fold,
//     R10.8 Property 14), format modern (.webp di public/images), alt via
//     resolveAltText (R11.1).
// Warna via CSS var saja (R6.4).
import type { Photo } from '../types.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  photos?: Photo[];
}

const { photos } = Astro.props;

const items = photos ?? [];

if (items.length === 0) return null;
---

<section class="gallery" aria-labelledby="gallery-h">
  <div class="container">
    <div class="gallery-head">
      <p class="eyebrow">Galeri Kami</p>
      <h2 id="gallery-h">Berdedikasi untuk kesejahteraan Anda</h2>
    </div>
    <ul class="gallery-grid" role="list">
      {
        items.map((photo, i) => (
          <li class="gallery-item" data-reveal style={`animation-delay:${0.05 * i}s`}>
            <div class="gallery-shot">
              <img
                src={`/images/${photo.url}`}
                alt={resolveAltText(photo)}
                width="400"
                height="300"
                loading="lazy"
                decoding="async"
              />
            </div>
            {photo.caption && (
              <figcaption class="gallery-cap">{photo.caption}</figcaption>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .gallery {
    background: var(--surface);
  }
  .gallery-head {
    text-align: center;
    max-width: 36ch;
    margin: 0 auto 2.5rem;
  }
  .gallery-head .eyebrow {
    justify-content: center;
  }
  .gallery h2 {
    font-size: clamp(1.7rem, 3.8vw, 2.6rem);
    margin: 0;
  }
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  }
  .gallery-item {
    margin: 0;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.65rem 0.65rem 0.9rem;
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s ease;
  }
  .gallery-item:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow);
  }
  .gallery-shot {
    position: relative;
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }
  .gallery-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .gallery-item:hover .gallery-shot img {
    transform: scale(1.05);
  }
  .gallery-cap {
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 0.75rem;
    padding-inline: 0.35rem;
  }
</style>
