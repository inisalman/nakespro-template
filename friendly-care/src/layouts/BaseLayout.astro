---
// layouts/BaseLayout.astro — shell semantik + injeksi palette.
//
// Tanggung jawab (R6.3, R6.4, R11.2):
//   - Menyusun shell HTML semantik dengan <html lang="id"> (R11.2).
//   - Me-resolve Palette_Preset terpilih lalu inject CSS custom properties
//     pada <html> via atribut style (R6.3). Komponen lain hanya memakai
//     var(--token) sehingga bebas warna literal (R6.4).
//   - Menyediakan <slot /> untuk section. Tepat satu <h1> berada di Hero,
//     bukan di sini (Property 13).
//
// Identitas visual friendly-care (R7.4): ramah/cerah, sangat rounded, hangat.
// Aksen maternal-care lembut — bentuk blob organik, panel kaca, bayangan
// halus berwarna aksen. File ini adalah SATU-SATUNYA lapisan token: nilai
// warna literal hanya boleh muncul di sini (didukung discipline test), seluruh
// komponen mereferensikan var(--token) atau color-mix di atasnya (R6.4).
import type { SiteContent } from '../types.ts';
import palettes, { DEFAULT_PALETTE_ID } from '../palettes.ts';
import { resolvePalette, paletteToCssVars } from '../lib/palette.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const palette = resolvePalette(palettes, content.palette, DEFAULT_PALETTE_ID);
const cssVars = paletteToCssVars(palette);
---

<!doctype html>
<html lang="id" style={cssVars}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={content.description} />
    <title>{content.websiteName}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-blobs" aria-hidden="true">
      <span class="blob blob-a"></span>
      <span class="blob blob-b"></span>
      <span class="blob blob-c"></span>
    </div>
    <slot />
    <style is:global>
      :root {
        --max-width: 1200px;
        --space: 1rem;
        /* friendly-care: ramah/cerah — sangat rounded (R7.4) & premium. */
        --radius-xs: 8px;
        --radius-sm: 14px;
        --radius: 20px;
        --radius-md: 26px;
        --radius-lg: 36px;
        --radius-xl: 44px;
        --radius-pill: 999px;

        /* Premium multi-layered accent-tinted shadows. */
        --shadow-xs: 0 2px 4px color-mix(in srgb, var(--accent) 3%, transparent);
        --shadow-sm: 0 4px 12px -2px color-mix(in srgb, var(--accent) 8%, transparent);
        --shadow: 0 12px 28px -8px color-mix(in srgb, var(--accent) 16%, transparent);
        --shadow-lg: 0 24px 48px -12px color-mix(in srgb, var(--accent) 24%, transparent);
        --shadow-xl: 0 36px 72px -16px color-mix(in srgb, var(--accent) 30%, transparent);

        /* Soft premium glass surfaces. */
        --glass-bg: rgba(255, 255, 255, 0.72);
        --glass-border: color-mix(in srgb, var(--accent) 12%, transparent);

        /* Palette derived surfaces. */
        --accent-strong: color-mix(in srgb, var(--accent) 88%, #000);
        --accent-soft: color-mix(in srgb, var(--accent) 8%, var(--background));
        --accent-softer: color-mix(in srgb, var(--accent) 4%, var(--background));
        --surface-2: color-mix(in srgb, var(--surface) 60%, var(--background));
        --hairline: color-mix(in srgb, var(--accent) 10%, transparent);
        --hairline-accent: color-mix(in srgb, var(--accent) 18%, transparent);
        --on-accent: var(--background);

        /* Service mesh gradients. */
        --grad-1: linear-gradient(135deg, color-mix(in srgb, var(--accent) 45%, #fff5f0) 0%, color-mix(in srgb, var(--accent) 20%, #ffece0) 50%, #ffd0dc 100%);
        --grad-2: linear-gradient(135deg, color-mix(in srgb, var(--accent) 30%, #fff8f0) 0%, color-mix(in srgb, var(--accent) 14%, #ffebf2) 50%, #eadaff 100%);
        --grad-3: linear-gradient(135deg, color-mix(in srgb, var(--accent) 22%, #fff0f4) 0%, #ffdeec 50%, color-mix(in srgb, var(--accent) 16%, #fff2ec) 100%);
        --grad-4: linear-gradient(135deg, color-mix(in srgb, var(--accent) 18%, #fff0f7) 0%, color-mix(in srgb, var(--accent) 12%, #faebff) 50%, #e3f2ff 100%);
        --grad-5: linear-gradient(135deg, color-mix(in srgb, var(--accent) 25%, #fff4f2) 0%, color-mix(in srgb, var(--accent) 16%, #ffebf5) 50%, #ebf5ff 100%);
        --grad-6: linear-gradient(135deg, color-mix(in srgb, var(--accent) 20%, #fff6f0) 0%, color-mix(in srgb, var(--accent) 18%, #ffebf3) 50%, #eff2ff 100%);
        --grad-fallback: linear-gradient(135deg, color-mix(in srgb, var(--accent) 35%, #fff3ec) 0%, color-mix(in srgb, var(--accent) 18%, #ffebf2) 100%);

        --on-dark: #ffffff;
        --on-dark-muted: rgba(255, 255, 255, 0.88);
        --on-dark-faint: rgba(255, 255, 255, 0.16);
        --on-dark-chip: rgba(255, 255, 255, 0.12);
        --hairline-dark: rgba(255, 255, 255, 0.10);
        --hairline-dark-hover: rgba(255, 255, 255, 0.22);

        --overlay-service-idle: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.6) 0%,
          rgba(0, 0, 0, 0.2) 50%,
          rgba(0, 0, 0, 0.02) 100%
        );
        --overlay-service-active: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.85) 0%,
          rgba(0, 0, 0, 0.45) 45%,
          rgba(0, 0, 0, 0.12) 75%,
          rgba(0, 0, 0, 0.02) 100%
        );
        --shadow-card-lift: 0 24px 50px -12px color-mix(in srgb, var(--accent) 25%, transparent), 0 8px 20px rgba(0, 0, 0, 0.06);

        --font-display: 'Plus Jakarta Sans', system-ui, -apple-system, 'Segoe UI', sans-serif;
        --font-sans:
          'Be Vietnam Pro', system-ui, -apple-system, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
      }
      * {
        box-sizing: border-box;
      }
      
      /* Premium custom scrollbar */
      ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
      }
      ::-webkit-scrollbar-track {
        background: var(--background);
      }
      ::-webkit-scrollbar-thumb {
        background: color-mix(in srgb, var(--accent) 20%, transparent);
        border: 2px solid var(--background);
        border-radius: var(--radius-pill);
      }
      ::-webkit-scrollbar-thumb:hover {
        background: color-mix(in srgb, var(--accent) 35%, transparent);
      }

      html {
        font-family: var(--font-sans);
        color: var(--text);
        background: var(--background);
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      body {
        margin: 0;
        position: relative;
        background:
          radial-gradient(
            1200px 600px at 85% -5%,
            var(--accent-softer),
            transparent 60%
          ),
          var(--background);
        color: var(--text);
        line-height: 1.7;
        overflow-x: hidden;
      }
      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-display);
        line-height: 1.2;
        color: var(--text);
        letter-spacing: -0.025em;
        font-weight: 700;
      }
      a {
        color: var(--accent-strong);
        transition: color 0.2s ease, transform 0.2s ease;
      }
      img {
        max-width: 100%;
        height: auto;
        display: block;
      }
      .container {
        width: 100%;
        max-width: var(--max-width);
        margin-inline: auto;
        padding-inline: clamp(1.5rem, 6vw, 3rem);
        position: relative;
        z-index: 1;
      }
      section {
        padding-block: clamp(4.5rem, 9vw, 6.5rem);
        position: relative;
      }
      /* Shared section header */
      .section-head {
        text-align: center;
        max-width: 46rem;
        margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
      }
      .section-kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-strong);
        background: var(--accent-soft);
        padding: 0.45rem 1.05rem;
        border: 1px solid var(--hairline-accent);
        border-radius: var(--radius-pill);
        margin: 0 0 1.2rem;
      }
      .section-title {
        font-size: clamp(1.85rem, 4.5vw, 2.75rem);
        font-weight: 800;
        margin: 0;
        line-height: 1.15;
        letter-spacing: -0.03em;
      }
      .section-lead {
        color: var(--muted);
        margin: 0.95rem auto 0;
        font-size: clamp(1.02rem, 1.8vw, 1.12rem);
        line-height: 1.6;
      }
      :where(a, button, [tabindex]):focus-visible {
        outline: 3px solid var(--accent);
        outline-offset: 3px;
        border-radius: var(--radius-xs);
      }

      /* Background decorative blobs - softer and elegant blend */
      .page-blobs {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }
      .blob {
        position: absolute;
        display: block;
        filter: blur(100px);
        opacity: 0.4;
        border-radius: 50%;
        mix-blend-mode: multiply;
      }
      .blob-a {
        top: -8%;
        right: -5%;
        width: 45vw;
        height: 45vw;
        background: color-mix(in srgb, var(--accent) 15%, transparent);
        animation: morph 20s ease-in-out infinite alternate;
      }
      .blob-b {
        top: 38%;
        left: -12%;
        width: 35vw;
        height: 35vw;
        background: color-mix(in srgb, var(--accent) 10%, transparent);
        animation: morph 25s ease-in-out infinite alternate-reverse;
      }
      .blob-c {
        bottom: -10%;
        right: 12%;
        width: 30vw;
        height: 30vw;
        background: color-mix(in srgb, var(--surface) 60%, var(--accent));
        animation: morph 22s ease-in-out infinite alternate;
      }
      @keyframes morph {
        0% {
          border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
          transform: translate3d(0, 0, 0) rotate(0deg);
        }
        50% {
          border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
          transform: translate3d(2%, -3%, 0) rotate(8deg);
        }
        100% {
          border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
          transform: translate3d(-2%, 2%, 0) rotate(-6deg);
        }
      }
      
      /* — Page-load stagger reveal — */
      [data-reveal] {
        animation: np-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
      @keyframes np-rise {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes np-fade {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      
      /* ── Fade-in per section saat masuk viewport ────────────────────── */
      .reveal-ready section {
        opacity: 0;
        transform: translateY(26px);
        transition:
          opacity 0.7s ease,
          transform 0.7s ease;
        will-change: opacity, transform;
      }
      .reveal-ready section.is-visible {
        opacity: 1;
        transform: none;
      }

      @media (prefers-reduced-motion: reduce) {
        [data-reveal] {
          animation: none !important;
          opacity: 1 !important;
          transform: none !important;
        }
        .blob {
          animation: none;
        }
        html {
          scroll-behavior: auto;
        }
      }
    </style>
    <script is:inline>
      document.documentElement.classList.add('reveal-ready');
      const revealEls = document.querySelectorAll('section');
      const reveal = (el) => el.classList.add('is-visible');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                reveal(entry.target);
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        requestAnimationFrame(() => {
          revealEls.forEach((el) => io.observe(el));
        });
      } else {
        revealEls.forEach(reveal);
      }
    </script>

  </body>
</html>
