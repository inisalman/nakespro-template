---
// layouts/BaseLayout.astro — shell semantik + injeksi palette.
//
// Tanggung jawab (R6.3, R6.4, R11.2):
//   - Menyusun shell HTML semantik dengan <html lang="id"> (R11.2).
//   - Me-resolve Palette_Preset terpilih lalu inject CSS custom properties
//     pada <html> via atribut style (R6.3). Komponen lain hanya memakai
//     var(--token) sehingga bebas warna literal (R6.4).
//   - Menyediakan <slot /> untuk section. Tepat satu <h1> berada di Hero,
//     bukan di sini (Property 13).
//
// Identitas visual friendly-care (R7.4): ramah/cerah, sangat rounded, hangat.
// Aksen maternal-care lembut — bentuk blob organik, panel kaca, bayangan
// halus berwarna aksen. File ini adalah SATU-SATUNYA lapisan token: nilai
// warna literal hanya boleh muncul di sini (didukung discipline test), seluruh
// komponen mereferensikan var(--token) atau color-mix di atasnya (R6.4).
import type { SiteContent } from '../types.ts';
import palettes, { DEFAULT_PALETTE_ID } from '../palettes.ts';
import { resolvePalette, paletteToCssVars } from '../lib/palette.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const palette = resolvePalette(palettes, content.palette, DEFAULT_PALETTE_ID);
const cssVars = paletteToCssVars(palette);
---

<!doctype html>
<html lang="id" style={cssVars}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={content.description} />
    <title>{content.websiteName}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-blobs" aria-hidden="true">
      <span class="blob blob-a"></span>
      <span class="blob blob-b"></span>
      <span class="blob blob-c"></span>
    </div>
    <slot />
    <style is:global>
      :root {
        --max-width: 1200px;
        --space: 1rem;
        /* friendly-care: ramah/cerah — sangat rounded (R7.4). */
        --radius: 24px;
        --radius-sm: 16px;
        --radius-pill: 999px;

        /* Bayangan halus bernuansa aksen (soft maternal-care). */
        --shadow: 0 18px 40px -16px color-mix(in srgb, var(--accent) 38%, transparent);
        --shadow-sm: 0 8px 24px -10px color-mix(in srgb, var(--accent) 30%, transparent);
        --shadow-lg: 0 30px 60px -22px color-mix(in srgb, var(--accent) 45%, transparent);

        /* Panel kaca translusen di atas latar. */
        --glass-bg: color-mix(in srgb, var(--background) 78%, transparent);
        --glass-border: color-mix(in srgb, var(--accent) 16%, transparent);

        /* Permukaan turunan untuk variasi tanpa warna literal di komponen. */
        --surface-2: color-mix(in srgb, var(--surface) 60%, var(--background));
        --accent-soft: color-mix(in srgb, var(--accent) 14%, var(--background));
        --accent-softer: color-mix(in srgb, var(--accent) 8%, var(--background));
        --hairline: color-mix(in srgb, var(--accent) 14%, transparent);
        --on-accent: var(--background);

        /* Service tile (expandable, gaya modern-light): token latar tile.
           Mesh pastel hangat (accent-tinted) sebagai fallback bila tidak ada
           foto. Overlay tipis agar foto tetap terasa cerah; lebih pekat saat
           tile aktif demi keterbacaan teks putih di atasnya. Literal hanya di
           sini (R6.4), komponen mereferensikan var(--token). */
        --grad-1: linear-gradient(135deg, color-mix(in srgb, var(--accent) 55%, #fff4e6) 0%, color-mix(in srgb, var(--accent) 30%, #ffe9d6) 50%, #ffd9e4 100%);
        --grad-2: linear-gradient(135deg, color-mix(in srgb, var(--accent) 35%, #fff0e0) 0%, color-mix(in srgb, var(--accent) 18%, #ffe1ee) 50%, #e7d9ff 100%);
        --grad-3: linear-gradient(135deg, color-mix(in srgb, var(--accent) 28%, #ffeaf0) 0%, #ffd6e8 50%, color-mix(in srgb, var(--accent) 22%, #ffe0d0) 100%);
        --grad-4: linear-gradient(135deg, color-mix(in srgb, var(--accent) 22%, #ffe6f0) 0%, color-mix(in srgb, var(--accent) 16%, #fde0ff) 50%, #e3f0ff 100%);
        --grad-5: linear-gradient(135deg, color-mix(in srgb, var(--accent) 30%, #ffe9e6) 0%, color-mix(in srgb, var(--accent) 20%, #ffe4f2) 50%, #e8f5ff 100%);
        --grad-6: linear-gradient(135deg, color-mix(in srgb, var(--accent) 26%, #fff0e8) 0%, color-mix(in srgb, var(--accent) 24%, #ffd9ea) 50%, #eef0ff 100%);
        --grad-fallback: linear-gradient(135deg, color-mix(in srgb, var(--accent) 40%, #fff0e6) 0%, color-mix(in srgb, var(--accent) 20%, #ffd9e4) 100%);
        /* Teks di atas tile gelap/foto (overlay) — putih untuk kontras. */
        --on-dark: #ffffff;
        --on-dark-muted: rgba(255, 255, 255, 0.82);
        --on-dark-faint: rgba(255, 255, 255, 0.16);
        --on-dark-chip: rgba(255, 255, 255, 0.14);
        --hairline-dark: rgba(255, 255, 255, 0.10);
        --hairline-dark-hover: rgba(255, 255, 255, 0.22);
        /* Overlay foto: idle tipis (foto tetap cerah), aktif pekat untuk keterbacaan. */
        --overlay-service-idle: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.55) 0%,
          rgba(0, 0, 0, 0.22) 45%,
          rgba(0, 0, 0, 0.04) 100%
        );
        --overlay-service-active: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.88) 0%,
          rgba(0, 0, 0, 0.52) 42%,
          rgba(0, 0, 0, 0.14) 75%,
          rgba(0, 0, 0, 0.04) 100%
        );
        --shadow-card-lift: 0 24px 60px -14px color-mix(in srgb, var(--accent) 32%, transparent), 0 8px 22px rgba(0, 0, 0, 0.14);

        --font-display: 'Plus Jakarta Sans', system-ui, -apple-system, 'Segoe UI', sans-serif;
        --font-sans:
          'Be Vietnam Pro', system-ui, -apple-system, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
      }
      * {
        box-sizing: border-box;
      }
      html {
        font-family: var(--font-sans);
        color: var(--text);
        background: var(--background);
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        position: relative;
        background:
          radial-gradient(
            1200px 600px at 85% -5%,
            var(--accent-softer),
            transparent 60%
          ),
          var(--background);
        color: var(--text);
        line-height: 1.65;
        overflow-x: hidden;
      }
      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-display);
        line-height: 1.15;
        color: var(--text);
        letter-spacing: -0.02em;
      }
      a {
        color: var(--accent);
      }
      img {
        max-width: 100%;
        height: auto;
        display: block;
      }
      .container {
        width: 100%;
        max-width: var(--max-width);
        margin-inline: auto;
        padding-inline: clamp(1rem, 5vw, 4rem);
        position: relative;
        z-index: 1;
      }
      section {
        padding-block: clamp(3rem, 7vw, 5.5rem);
        position: relative;
      }
      /* Judul section bersama: kicker + heading + lead opsional. */
      .section-head {
        text-align: center;
        max-width: 44rem;
        margin: 0 auto clamp(2rem, 4vw, 3rem);
      }
      .section-kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 0.4rem 0.9rem;
        border-radius: var(--radius-pill);
        margin: 0 0 1rem;
      }
      .section-title {
        font-size: clamp(1.7rem, 4vw, 2.6rem);
        margin: 0;
      }
      .section-lead {
        color: var(--muted);
        margin: 0.85rem auto 0;
        font-size: clamp(1rem, 2vw, 1.1rem);
      }
      :where(a, button, [tabindex]):focus-visible {
        outline: 3px solid var(--accent);
        outline-offset: 3px;
      }

      /* Latar blob organik ambient (dekoratif, di belakang konten). */
      .page-blobs {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }
      .blob {
        position: absolute;
        display: block;
        filter: blur(60px);
        opacity: 0.5;
        border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
        animation: morph 16s ease-in-out infinite alternate;
      }
      .blob-a {
        top: -8%;
        right: -6%;
        width: 38vw;
        height: 38vw;
        background: color-mix(in srgb, var(--accent) 30%, transparent);
      }
      .blob-b {
        top: 38%;
        left: -10%;
        width: 30vw;
        height: 30vw;
        background: color-mix(in srgb, var(--accent) 18%, transparent);
        animation-delay: -6s;
      }
      .blob-c {
        bottom: -10%;
        right: 12%;
        width: 26vw;
        height: 26vw;
        background: color-mix(in srgb, var(--surface) 70%, var(--accent));
        animation-delay: -11s;
      }
      @keyframes morph {
        0% {
          border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
          transform: translate3d(0, 0, 0) rotate(0deg);
        }
        50% {
          border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
          transform: translate3d(2%, -3%, 0) rotate(8deg);
        }
        100% {
          border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
          transform: translate3d(-2%, 2%, 0) rotate(-6deg);
        }
      }
      
      /* — Page-load stagger reveal — */
      [data-reveal] {
        animation: np-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
      @keyframes np-rise {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes np-fade {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      
      /* ── Fade-in per section saat masuk viewport ────────────────────── */
      .reveal-ready section {
        opacity: 0;
        transform: translateY(26px);
        transition:
          opacity 0.7s ease,
          transform 0.7s ease;
        will-change: opacity, transform;
      }
      .reveal-ready section.is-visible {
        opacity: 1;
        transform: none;
      }

      @media (prefers-reduced-motion: reduce) {
        [data-reveal] {
          animation: none !important;
          opacity: 1 !important;
          transform: none !important;
        }
        .blob {
          animation: none;
        }
        html {
          scroll-behavior: auto;
        }
      }
    </style>
    <script is:inline>
      document.documentElement.classList.add('reveal-ready');
      const revealEls = document.querySelectorAll('section');
      const reveal = (el) => el.classList.add('is-visible');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                reveal(entry.target);
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        requestAnimationFrame(() => {
          revealEls.forEach((el) => io.observe(el));
        });
      } else {
        revealEls.forEach(reveal);
      }
    </script>

  </body>
</html>
