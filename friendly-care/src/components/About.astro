---
// components/About.astro — section 4, Auto-Hide (R3.7, R5.3).
//
// Guard: about kosong (whitespace-only termasuk) → return null (R5.3).
// Warna via CSS var saja (R6.4). Konten about bisa multi-paragraf: pisah
// per baris kosong agar terbaca.
import { isEmptyText } from '../lib/empty.ts';

interface Props {
  text?: string;
}

const { text } = Astro.props;
if (isEmptyText(text)) return null;
const paragraphs = (text as string)
  .trim()
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter((p) => p.length > 0);
---

<section class="about" aria-labelledby="about-h">
  <div class="container">
    <div class="about-card">
      <span class="section-kicker">Tentang Kami</span>
      <h2 id="about-h" class="about-title" data-reveal style="animation-delay:.12s">Hadir dengan sentuhan lembut</h2>
      {paragraphs.map((p) => <p class="about-p">{p}</p>)}
    </div>
  </div>
</section>

<style>
  .about-card {
    position: relative;
    max-width: 72ch;
    margin-inline: auto;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: clamp(1.75rem, 4vw, 3rem);
    box-shadow: var(--shadow-sm);
  }
  .about-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    margin: 0 0 1.25rem;
  }
  .about-p {
    color: var(--muted);
    margin: 0 0 1.1rem;
    font-size: 1.04rem;
  }
  .about-p:last-child {
    margin-bottom: 0;
  }
</style>
