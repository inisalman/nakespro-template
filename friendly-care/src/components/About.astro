---
// components/About.astro — section 4, Auto-Hide (R3.7, R5.3).
//
// Guard: about kosong (whitespace-only termasuk) → return null (R5.3).
// Warna via CSS var saja (R6.4). Konten about bisa multi-paragraf: pisah
// per baris kosong agar terbaca.
import { isEmptyText } from '../lib/empty.ts';

interface Props {
  text?: string;
}

const { text } = Astro.props;
if (isEmptyText(text)) return null;
const paragraphs = (text as string)
  .trim()
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter((p) => p.length > 0);
---

<section class="about" aria-labelledby="about-h">
  <div class="container">
    <div class="about-card">
      <span class="section-kicker">Tentang Kami</span>
      <h2 id="about-h" class="about-title" data-reveal style="animation-delay:.12s">Hadir dengan sentuhan lembut</h2>
      {paragraphs.map((p) => <p class="about-p">{p}</p>)}
    </div>
  </div>
</section>

<style>
  .about-card {
    position: relative;
    max-width: 76ch;
    margin-inline: auto;
    background: linear-gradient(135deg, var(--glass-bg) 0%, color-mix(in srgb, var(--surface) 25%, var(--glass-bg)) 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: clamp(2rem, 5vw, 3.5rem);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .about-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 6px;
    background: linear-gradient(to bottom, var(--accent), color-mix(in srgb, var(--accent) 70%, transparent));
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
  }
  .about-title {
    font-size: clamp(1.85rem, 4.5vw, 2.5rem);
    margin: 0 0 1.5rem;
    line-height: 1.25;
    letter-spacing: -0.025em;
  }
  .about-p {
    color: var(--muted);
    margin: 0 0 1.25rem;
    font-size: 1.05rem;
    line-height: 1.75;
    text-wrap: pretty;
  }
  .about-p:last-child {
    margin-bottom: 0;
  }
</style>
