---
// components/HowItWorks.astro — section 6, Auto-Hide (R3.9, R3.12, R5.3).
//
// Guard: howItWorks kosong → return null (R5.3). Render SELURUH entri terurut
// sesuai urutan pada data (Property 8). Warna via CSS var saja (R6.4).
import type { HowItWorksStep } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  steps?: HowItWorksStep[];
}

const { steps } = Astro.props;
if (isEmptyList(steps)) return null;
const howItWorks = steps as HowItWorksStep[];
---

<section class="how" aria-labelledby="how-h">
  <div class="container">
    <div class="section-head">
      <span class="section-kicker">Cara Kerja</span>
      <h2 id="how-h" class="section-title" data-reveal style="animation-delay:.15s">Mudah & Menyenangkan</h2>
      <p class="section-lead">
        Hanya beberapa langkah sederhana untuk mulai dirawat di rumah Anda.
      </p>
    </div>
    <ol class="how-list">
      {
        howItWorks.map((s) => (
          <li class="how-step">
            <span class="how-num" aria-hidden="true">
              {s.step}
            </span>
            <div class="how-body">
              <h3 class="how-title">{s.title}</h3>
              <p class="how-desc">{s.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }
  .how-step {
    position: relative;
    background: linear-gradient(135deg, var(--background) 0%, color-mix(in srgb, var(--surface) 20%, var(--background)) 100%);
    border: 1px solid var(--hairline-accent);
    border-radius: var(--radius-md);
    padding: 2.25rem 1.75rem 1.75rem;
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s ease;
  }
  .how-step:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }
  .how-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    background: var(--accent);
    color: var(--on-accent);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.15rem;
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .how-title {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }
  .how-desc {
    margin: 0;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.6;
  }
</style>
