---
// components/Hero.astro — section 1, selalu render (R5.5), tidak Auto-Hide.
//
// Menampilkan (R3.3, R11.2, R11.4):
//   - Tepat satu <h1> halaman (websiteName) → struktur heading (Property 13).
//   - Tagline opsional sebagai sub-judul (di-highlight).
//   - Foto utama dari content.heroPhoto dengan width/height eksplisit +
//     fetchpriority high (above-the-fold, tidak lazy) (R3.3, R10.8, Property 14).
//   - WhatsApp_CTA above-the-fold dengan accessible name tidak kosong (R3.3,
//     R3.4, R11.4). CTA selalu tampil di Hero; href tetap dibangun dari nomor.
//   - Badge mengambang opsional dari kredensial pertama (kepercayaan).
// Warna hanya via var(--token)/color-mix (R6.4).
import type { SiteContent } from '../types.ts';
import { buildWaUrl, isValidWaNumber } from '../lib/whatsapp.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const heroPhoto = content.heroPhoto;
const heroAlt = heroPhoto
  ? resolveAltText(heroPhoto)
  : `Foto ${content.websiteName}`;
const heroSrc = heroPhoto ? `/images/${heroPhoto.url}` : undefined;
const waValid = isValidWaNumber(content.waNumber);
const waHref = buildWaUrl(content.waNumber, content.waMessage);
const badge = content.credentials?.[0];
---

<section class="hero" aria-labelledby="hero-h">
  <div class="container hero-grid">
    <div class="hero-copy">
      {
        content.tagline && (
          <span class="hero-pill" data-reveal style="animation-delay:.05s">
            <span class="hero-pill-dot" aria-hidden="true" />
            {content.tagline}
          </span>
        )
      }
      <h1 id="hero-h" data-reveal style="animation-delay:.12s" class="hero-title">
        <span class="hero-mark">{content.websiteName}</span>
      </h1>
      <p class="hero-desc" data-reveal style="animation-delay:.25s">{content.description}</p>
      <div class="hero-actions" data-reveal style="animation-delay:.35s">
        {
          waValid && (
            <a
              class="btn btn-primary"
              href={waHref}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Hubungi kami via WhatsApp"
            >
              Konsultasi Sekarang
              <svg
                viewBox="0 0 24 24"
                width="18"
                height="18"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          )
        }
        <a class="btn btn-ghost" href="#services-h">Lihat Layanan</a>
      </div>
    </div>

    {
      heroSrc && (
        <div class="hero-media" data-reveal style="animation-delay:.2s">
          <div class="hero-frame">
            <img
              src={heroSrc}
              alt={heroAlt}
              width="640"
              height="720"
              decoding="async"
              fetchpriority="high"
            />
          </div>
          {badge && (
            <div class="hero-badge">
              <span class="hero-badge-icon" aria-hidden="true">
                {badge.icon}
              </span>
              <span class="hero-badge-text">{badge.label}</span>
            </div>
          )}
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(2.5rem, 6vw, 4.5rem);
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }
  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--accent-soft);
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.86rem;
    padding: 0.45rem 0.95rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--hairline);
    margin: 0 0 1.25rem;
  }
  .hero-pill-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }
  .hero-title {
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    font-weight: 800;
    margin: 0 0 1.1rem;
  }
  .hero-mark {
    background: linear-gradient(
      120deg,
      var(--text) 30%,
      var(--accent) 110%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-desc {
    color: var(--muted);
    font-size: clamp(1.02rem, 2vw, 1.18rem);
    margin: 0 0 2rem;
    max-width: 40ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 52px;
    padding: 0.9rem 1.7rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.98rem;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--on-accent);
    box-shadow: var(--shadow);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .btn-ghost {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--hairline);
  }
  .btn-ghost:hover {
    background: var(--accent-soft);
    border-color: var(--accent);
  }

  .hero-media {
    position: relative;
    max-width: 460px;
    margin-inline: auto;
    width: 100%;
  }
  .hero-frame {
    position: relative;
    border-radius: 32px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    z-index: 1;
  }
  .hero-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero-media::after {
    content: '';
    position: absolute;
    inset: -6% 8% 10% -6%;
    background: var(--accent-soft);
    border-radius: 36% 64% 60% 40% / 50% 40% 60% 50%;
    z-index: 0;
    animation: morph 14s ease-in-out infinite alternate;
  }
  .hero-frame img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }
  .hero-badge {
    position: absolute;
    left: -1.1rem;
    bottom: 1.4rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.7rem 1rem;
    border-radius: var(--radius-sm);
    background: var(--glass-bg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-sm);
    max-width: 15rem;
  }
  .hero-badge-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 1.15rem;
  }
  .hero-badge-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.2;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-media::after {
      animation: none;
    }
  }
</style>
