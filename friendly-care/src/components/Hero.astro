---
// components/Hero.astro — section 1, selalu render (R5.5), tidak Auto-Hide.
//
// Menampilkan (R3.3, R11.2, R11.4):
//   - Tepat satu <h1> halaman (websiteName) → struktur heading (Property 13).
//   - Tagline opsional sebagai sub-judul (di-highlight).
//   - Foto utama dari content.heroPhoto dengan width/height eksplisit +
//     fetchpriority high (above-the-fold, tidak lazy) (R3.3, R10.8, Property 14).
//   - WhatsApp_CTA above-the-fold dengan accessible name tidak kosong (R3.3,
//     R3.4, R11.4). CTA selalu tampil di Hero; href tetap dibangun dari nomor.
//   - Badge mengambang opsional dari kredensial pertama (kepercayaan).
// Warna hanya via var(--token)/color-mix (R6.4).
import type { SiteContent } from '../types.ts';
import { buildWaUrl, isValidWaNumber } from '../lib/whatsapp.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const heroPhoto = content.heroPhoto;
const heroAlt = heroPhoto
  ? resolveAltText(heroPhoto)
  : `Foto ${content.websiteName}`;
const heroSrc = heroPhoto ? `/images/${heroPhoto.url}` : undefined;
const waValid = isValidWaNumber(content.waNumber);
const waHref = buildWaUrl(content.waNumber, content.waMessage);
const badges = (content.credentials || []).slice(0, 3);
---

<section class="hero" aria-labelledby="hero-h">
  <div class="container hero-grid">
    <div class="hero-copy">
      {
        content.tagline && (
          <span class="hero-pill" data-reveal style="animation-delay:.05s">
            <span class="hero-pill-dot" aria-hidden="true" />
            {content.tagline}
          </span>
        )
      }
      <h1 id="hero-h" data-reveal style="animation-delay:.12s" class="hero-title">
        <span class="hero-mark">{content.websiteName}</span>
      </h1>
      <p class="hero-desc" data-reveal style="animation-delay:.25s">{content.description}</p>
      <div class="hero-actions" data-reveal style="animation-delay:.35s">
        {
          waValid && (
            <a
              class="btn btn-primary"
              href={waHref}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Hubungi kami via WhatsApp"
            >
              Konsultasi Sekarang
              <svg
                viewBox="0 0 24 24"
                width="18"
                height="18"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          )
        }
        <a class="btn btn-ghost" href="#services-h">Lihat Layanan</a>
      </div>
    </div>

    {
      heroSrc && (
        <div class="hero-media" data-reveal style="animation-delay:.2s">
          <div class="hero-frame">
            <img
              src={heroSrc}
              alt={heroAlt}
              width="640"
              height="720"
              decoding="async"
              fetchpriority="high"
            />
          </div>
            <ul class="hero-badges" aria-label="Kredensial">
            {badges.map((b, i) => (
              <li class={`hero-badge-item hero-badge-item--${i + 1}`}>
                <span class="hero-badge-ico" aria-hidden="true">{b.icon}</span>
                <span class="hero-badge-txt">{b.label}</span>
              </li>
            ))}
          </ul>
          
          
        </div>
      )
    }
  </div>
</section>

<style>
  @keyframes bp {
    from { opacity: 0; transform: scale(0.85) translateY(12px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes floatBadge1 {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-10px) rotate(1deg); }
  }
  @keyframes floatBadge2 {
    0%, 100% { transform: translateY(0) rotate(1deg); }
    50% { transform: translateY(-8px) rotate(-1deg); }
  }
  @keyframes floatBadge3 {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(1deg); }
  }

  .hero {
    padding-top: clamp(3rem, 7vw, 5.5rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4.5rem);
    align-items: center;
  }
  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }
  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.5rem 1.15rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--hairline-accent);
    margin: 0 0 1.5rem;
  }
  .hero-pill-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
  }
  .hero-title {
    font-size: clamp(2.4rem, 6.5vw, 3.8rem);
    font-weight: 800;
    margin: 0 0 1.25rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }
  .hero-mark {
    background: linear-gradient(
      135deg,
      var(--text) 30%,
      var(--accent-strong) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-desc {
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    margin: 0 0 2.5rem;
    line-height: 1.75;
    max-width: 44ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 54px;
    padding: 0.95rem 1.85rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition:
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.25s ease,
      border-color 0.25s ease;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--on-accent);
    box-shadow: var(--shadow-lg);
  }
  .btn-primary:hover {
    transform: translateY(-3px);
    background: var(--accent-strong);
    box-shadow: var(--shadow-xl);
  }
  .btn-primary:active {
    transform: translateY(0);
  }
  .btn-ghost {
    background: var(--glass-bg);
    color: var(--accent-strong);
    border: 2px solid var(--hairline-accent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .btn-ghost:hover {
    background: var(--accent-soft);
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .btn-ghost:active {
    transform: translateY(0);
  }

  .hero-media {
    position: relative;
    max-width: 460px;
    margin-inline: auto;
    width: 100%;
  }
  .hero-frame {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 6px solid var(--background);
    box-shadow: var(--shadow-xl);
    z-index: 1;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-frame:hover {
    transform: scale(1.02);
  }
  .hero-media::after {
    content: '';
    position: absolute;
    inset: -6% 8% 10% -6%;
    background: var(--accent-soft);
    border-radius: 36% 64% 60% 40% / 50% 40% 60% 50%;
    z-index: 0;
    animation: morph 14s ease-in-out infinite alternate;
  }
  .hero-frame img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }
  .hero-badges {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }
  .hero-badge-item {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.15rem;
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
    pointer-events: auto;
    z-index: 3;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease;
  }
  .hero-badge-item:hover {
    transform: scale(1.06) translateY(-3px) !important;
    background: var(--background);
    box-shadow: var(--shadow);
  }
  .hero-badge-ico {
    font-size: 1.15rem;
    line-height: 1;
    color: var(--accent-strong);
  }
  .hero-badge-item:nth-child(1) {
    top: 8%;
    left: -8%;
    animation: bp .5s cubic-bezier(.22,1,.36,1) both, floatBadge1 5s ease-in-out infinite;
    animation-delay: .7s, .7s;
  }
  .hero-badge-item:nth-child(2) {
    top: 45%;
    right: -8%;
    animation: bp .5s cubic-bezier(.22,1,.36,1) both, floatBadge2 5.5s ease-in-out infinite;
    animation-delay: .95s, .95s;
  }
  .hero-badge-item:nth-child(3) {
    bottom: 8%;
    left: -4%;
    animation: bp .5s cubic-bezier(.22,1,.36,1) both, floatBadge3 6s ease-in-out infinite;
    animation-delay: 1.2s, 1.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-media::after {
      animation: none;
    }
    .hero-badge-item {
      animation: none !important;
    }
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
      gap: 0.8rem;
    }
    .btn {
      width: 100%;
    }
    .hero-badge-item {
      display: none;
  }
</style>
