---
// components/ContactLocation.astro — section 8, Auto-Hide penuh + partial
// (R3.11, R3.14, R5.3, R5.6, Property 5).
//
// Aturan render:
//   - Section dirender bila ≥1 sub-field (practiceHours, location, googleMaps)
//     tidak kosong; bila semua kosong → return null (R5.3).
//   - Render HANYA sub-field tidak kosong, tanpa placeholder (R5.6).
//   - Bila googleMaps kosong tapi sub-field lain ada: section tetap tampil
//     dengan indikasi peta tidak tersedia (R3.14).
//   - Iframe Maps punya title tidak kosong (accessible name) (R11.6).
// Warna via CSS var saja (R6.4).
import { isEmptyText } from '../lib/empty.ts';

interface Props {
  practiceHours?: string;
  location?: string;
  googleMaps?: string;
}

const { practiceHours, location, googleMaps } = Astro.props;

const hasHours = !isEmptyText(practiceHours);
const hasLocation = !isEmptyText(location);
const hasMaps = !isEmptyText(googleMaps);

if (!hasHours && !hasLocation && !hasMaps) return null;

// Sub-field non-maps menentukan apakah indikasi "peta tidak tersedia"
// ditampilkan (hanya bila ada konteks kontak lain namun maps kosong, R3.14).
const showMapUnavailable = !hasMaps && (hasHours || hasLocation);
---

<section class="contact" aria-labelledby="contact-h">
  <div class="container contact-grid">
    <div class="contact-info">
      <span class="section-kicker">Kontak</span>
      <h2 id="contact-h" class="contact-title">Kontak &amp; Lokasi</h2>
      {
        hasHours && (
          <div class="contact-block">
            <span class="contact-ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3 2" />
              </svg>
            </span>
            <div>
              <h3 class="contact-label">Jam Praktik</h3>
              <p class="contact-value">{practiceHours}</p>
            </div>
          </div>
        )
      }
      {
        hasLocation && (
          <div class="contact-block">
            <span class="contact-ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z" />
                <circle cx="12" cy="10" r="2.5" />
              </svg>
            </span>
            <div>
              <h3 class="contact-label">Area Layanan</h3>
              <p class="contact-value">{location}</p>
            </div>
          </div>
        )
      }
      {
        showMapUnavailable && (
          <p class="map-unavailable">Peta lokasi tidak tersedia saat ini.</p>
        )
      }
    </div>
    {
      hasMaps && (
        <div class="contact-map">
          <iframe
            src={googleMaps}
            title="Peta lokasi praktik"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        </div>
      )
    }
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .contact-title {
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    margin: 0 0 1.75rem;
  }
  .contact-block {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .contact-ic {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    background: var(--accent-soft);
    color: var(--accent);
  }
  .contact-label {
    font-size: 1rem;
    font-family: var(--font-display);
    color: var(--text);
    margin: 0 0 0.2rem;
  }
  .contact-value {
    margin: 0;
    color: var(--muted);
  }
  .map-unavailable {
    color: var(--muted);
    font-style: italic;
  }
  .contact-map {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    border: 1px solid var(--glass-border);
  }
  .contact-map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
