---
// components/Footer.astro — selalu render, dikecualikan dari Auto-Hide (R5.5).
//
// Menampilkan teks kecil "Powered by NakesPro" (R3.15). Warna hanya via CSS
// custom properties hasil palette (R6.4) — tanpa nilai warna literal.
---

<footer class="site-footer">
  <div class="container footer-inner">
    <span class="footer-mark" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
        <path
          d="M12 21s-6.7-4.35-9.2-8.06C1.2 10.6 1.7 7.3 4.2 6c2-1.05 4.2-.3 5.4 1.2L12 9l2.4-1.8c1.2-1.5 3.4-2.25 5.4-1.2 2.5 1.3 3 4.6 1.4 6.94C18.7 16.65 12 21 12 21Z"
        ></path>
      </svg>
    </span>
    <p class="powered">Powered by NakesPro</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--hairline);
    background: var(--accent-softer);
    padding-block: 2.25rem;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }
  .footer-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    background: var(--accent);
    color: var(--on-accent);
    box-shadow: var(--shadow-sm);
  }
  .powered {
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
  }
</style>
