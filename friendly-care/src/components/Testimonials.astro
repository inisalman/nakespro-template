---
// components/Testimonials.astro — section 7, Auto-Hide (R3.10, R3.12, R5.3).
//
// Guard: testimonials kosong → return null (R5.3). Render SELURUH entri
// (Property 8). Warna via CSS var saja (R6.4).
import type { Testimonial } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  items?: Testimonial[];
}

const { items } = Astro.props;
if (isEmptyList(items)) return null;
const testimonials = items as Testimonial[];
---

<section class="testimonials" aria-labelledby="testimonials-h">
  <div class="container">
    <div class="section-head">
      <span class="section-kicker">Testimoni</span>
      <h2 id="testimonials-h" class="section-title" data-reveal style="animation-delay:.18s">Apa Kata Mereka</h2>
    </div>
    <ul class="testi-grid" role="list">
      {
        testimonials.map((t) => (
          <li class="testi-card">
            <div class="testi-stars" aria-hidden="true">
              <span>★</span>
              <span>★</span>
              <span>★</span>
              <span>★</span>
              <span>★</span>
            </div>
            <blockquote class="testi-quote">{t.text}</blockquote>
            <div class="testi-meta">
              <span class="testi-avatar" aria-hidden="true">
                {t.name.trim().charAt(0)}
              </span>
              <span class="testi-who">
                <span class="testi-name">{t.name}</span>
                {t.role && <span class="testi-role">{t.role}</span>}
              </span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .testi-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.4rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .testi-card {
    background: var(--background);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }
  .testi-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow);
  }
  .testi-stars {
    display: flex;
    gap: 0.15rem;
    color: var(--accent);
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .testi-quote {
    margin: 0 0 1.5rem;
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.6;
  }
  .testi-meta {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .testi-avatar {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.2rem;
    text-transform: uppercase;
  }
  .testi-who {
    display: flex;
    flex-direction: column;
  }
  .testi-name {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--text);
  }
  .testi-role {
    font-size: 0.875rem;
    color: var(--muted);
  }
</style>
