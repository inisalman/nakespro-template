---
// components/Testimonials.astro — section 7, Auto-Hide (R3.10, R3.12, R5.3).
//
// Guard: testimonials kosong → return null (R5.3). Render SELURUH entri
// (Property 8). Warna via CSS var saja (R6.4).
import type { Testimonial } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  items?: Testimonial[];
}

const { items } = Astro.props;
if (isEmptyList(items)) return null;
const testimonials = items as Testimonial[];
---

<section class="testimonials" aria-labelledby="testimonials-h">
  <div class="container">
    <div class="section-head">
      <span class="section-kicker">Testimoni</span>
      <h2 id="testimonials-h" class="section-title" data-reveal style="animation-delay:.18s">Apa Kata Mereka</h2>
    </div>
    <ul class="testi-grid" role="list">
      {
        testimonials.map((t) => (
          <li class="testi-card">
            <div class="testi-stars" aria-hidden="true">
              <span>★</span>
              <span>★</span>
              <span>★</span>
              <span>★</span>
              <span>★</span>
            </div>
            <blockquote class="testi-quote">{t.text}</blockquote>
            <div class="testi-meta">
              <span class="testi-avatar" aria-hidden="true">
                {t.name.trim().charAt(0)}
              </span>
              <span class="testi-who">
                <span class="testi-name">{t.name}</span>
                {t.role && <span class="testi-role">{t.role}</span>}
              </span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .testi-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.75rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .testi-card {
    background: linear-gradient(135deg, var(--background) 0%, color-mix(in srgb, var(--surface) 30%, var(--background)) 100%);
    border-radius: var(--radius-md);
    padding: 2.25rem 2rem;
    border: 1px solid var(--hairline-accent);
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s ease;
  }
  .testi-card:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
    box-shadow: var(--shadow-lg);
  }
  .testi-stars {
    display: flex;
    gap: 0.2rem;
    color: var(--accent);
    text-shadow: 0 2px 4px color-mix(in srgb, var(--accent) 20%, transparent);
    font-size: 1.1rem;
    margin-bottom: 1.25rem;
  }
  .testi-quote {
    margin: 0 0 1.75rem;
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.7;
    font-style: italic;
    text-wrap: pretty;
  }
  .testi-meta {
    display: flex;
    align-items: center;
    gap: 0.95rem;
  }
  .testi-avatar {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.15rem;
    text-transform: uppercase;
    box-shadow: var(--shadow-xs);
    border: 1px solid var(--hairline-accent);
  }
  .testi-who {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .testi-name {
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--text);
    font-size: 0.96rem;
  }
  .testi-role {
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--muted);
  }
</style>
