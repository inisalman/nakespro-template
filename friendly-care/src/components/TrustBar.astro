---
// components/TrustBar.astro — section 2, Auto-Hide (R3.5, R3.12, R5.3).
//
// Guard: bila credentials kosong → return null (tidak emit elemen/heading/
// container apa pun) (R5.3). Bila ada, render SELURUH entri (Property 8).
// Warna via CSS var saja (R6.4).
import type { Credential } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';

interface Props {
  items?: Credential[];
}

const { items } = Astro.props;
if (isEmptyList(items)) return null;
const credentials = items as Credential[];
---

<section class="trustbar" aria-labelledby="trustbar-h">
  <div class="container">
    <h2 id="trustbar-h" class="visually-hidden">Kredensial &amp; Sertifikasi</h2>
    <ul class="trust-list" role="list">
      {
        credentials.map((c) => (
          <li class="trust-item">
            {c.icon && (
              <span class="trust-icon" aria-hidden="true">
                {c.icon}
              </span>
            )}
            <span class="trust-label">{c.label}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .trustbar {
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
    z-index: 10;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .trust-list {
    list-style: none;
    margin: 0;
    padding: clamp(1.2rem, 2.5vw, 1.8rem) clamp(1.5rem, 4vw, 2.5rem);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.75rem;
    justify-content: center;
    align-items: center;
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1.15rem;
    border-radius: var(--radius-pill);
    background: var(--accent-softer);
    border: 1px solid var(--hairline-accent);
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    transition: transform 0.25s ease, background-color 0.25s ease;
  }
  .trust-item:hover {
    transform: translateY(-2px);
    background: var(--accent-soft);
  }
  .trust-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    line-height: 1;
    color: var(--accent-strong);
  }
</style>
