---
// components/PhotoGallery.astro — section 5, Auto-Hide per kategori (R3.8,
// R3.13, R5.3, Property 5/8).
//
// Aturan render:
//   - Section dirender bila ada ≥1 foto di kategori mana pun; bila semua
//     kategori kosong → return null (R5.3).
//   - Hanya grup kategori tidak kosong yang dirender; grup kosong disembunyikan
//     (R3.13). Urutan kategori tetap: nakes, ruangan, alat, hasil.
//   - Tiap gambar: width/height eksplisit, loading="lazy" (below-the-fold,
//     R10.8 Property 14), format modern (.webp di public/images), alt via
//     resolveAltText (R11.1).
// Warna via CSS var saja (R6.4).
import type { PhotoSet } from '../types.ts';
import { isEmptyList } from '../lib/empty.ts';
import { resolveAltText } from '../lib/images.ts';

interface Props {
  photos?: PhotoSet;
}

const LABELS: Record<keyof PhotoSet, string> = {
  nakes: 'Tenaga Kesehatan',
  ruangan: 'Ruangan',
  alat: 'Peralatan',
  hasil: 'Hasil',
};
const ORDER: (keyof PhotoSet)[] = ['nakes', 'ruangan', 'alat', 'hasil'];

const { photos } = Astro.props;

const groups = photos
  ? ORDER.filter((cat) => !isEmptyList(photos[cat])).map((cat) => ({
      cat,
      label: LABELS[cat],
      items: photos[cat],
    }))
  : [];

if (groups.length === 0) return null;
---

<section class="gallery" aria-labelledby="gallery-h">
  <div class="container">
    <div class="section-head">
      <span class="section-kicker">Dokumentasi</span>
      <h2 id="gallery-h" class="section-title">Galeri</h2>
      <p class="section-lead">
        Momen-momen penuh kasih dalam setiap pelayanan untuk Anda dan buah hati.
      </p>
    </div>
    {
      groups.map((group) => (
        <div class="gallery-group">
          <h3 class="gallery-cat">{group.label}</h3>
          <ul class="gallery-grid" role="list">
            {group.items.map((photo) => (
              <li class="gallery-item">
                <figure class="gallery-fig">
                  <img
                    src={`/images/${photo.url}`}
                    alt={resolveAltText(photo)}
                    width="400"
                    height="300"
                    loading="lazy"
                    decoding="async"
                  />
                  {photo.caption && (
                    <figcaption class="gallery-cap">{photo.caption}</figcaption>
                  )}
                </figure>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  .gallery-group {
    margin-bottom: 2.5rem;
  }
  .gallery-group:last-child {
    margin-bottom: 0;
  }
  .gallery-cat {
    display: inline-block;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
    margin: 0 0 1.1rem;
  }
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  }
  .gallery-item {
    margin: 0;
  }
  .gallery-fig {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    aspect-ratio: 4 / 3;
  }
  .gallery-fig img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .gallery-fig:hover img {
    transform: scale(1.07);
  }
  .gallery-cap {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.5rem 1rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--on-accent);
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--accent) 85%, transparent),
      transparent
    );
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }
  .gallery-fig:hover .gallery-cap,
  .gallery-fig:focus-within .gallery-cap {
    opacity: 1;
    transform: translateY(0);
  }
</style>
